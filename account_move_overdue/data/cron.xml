<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action for Overdue Payment Check -->
        <record id="ir_cron_check_overdue_payments" model="ir.cron">
            <field name="name">Check Overdue Payments and Send Notifications</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._check_overdue_payments_and_send()</field>
            <field name="interval_number">3</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta()).strftime('%Y-%m-%d 09:00:00')"/>
        </record>
    </data>
</odoo> 