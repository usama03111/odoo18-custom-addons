<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_partner_form_overdue_reminder" model="ir.ui.view">
        <field name="name">res.partner.form.overdue.reminder</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Add inside Sales & Purchase tab -->
            <xpath expr="//page[@name='sales_purchases']/group[@name='container_row_2']" position="inside">
                <group string="Overdue Payment Settings" name="overdue_settings">
                    <field name="send_overdue_reminder" widget="boolean_toggle"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
