<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Directory list view -->
    <record id="view_document_directory_filter" model="ir.ui.view">
        <field name="name">document.directory.search</field>
        <field name="model">document.directory</field>
        <field name="arch" type="xml">
            <search string="Search Directory">
                <field name="name"/>
                <field name="description"/>
                <field name="res_model"/>
                <field name="tag_ids" string="Tag" filter_domain="[('tag_ids', 'ilike', self)]"/>
                <separator/>
                <group expand="0" string="Group By">
                </group>
                <searchpanel>
                    <field name="parent_id" icon="fa-filter" limit="0"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="document_directory_list_view" model="ir.ui.view">
        <field name="name">document.directory.list</field>
        <field name="model">document.directory</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Document Page">
                <field name="name"/>
                <field name="user_ids"/>
            </list>
        </field>
    </record>

    <record id="document_directory_form_view" model="ir.ui.view">
        <field name="name">document.directory.form</field>
        <field name="model">document.directory</field>
        <field name="arch" type="xml">
            <form string="Document Directory">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button  class="oe_stat_button" name="action_view_attachments"  type="object" icon="fa-files-o">
                            <field string="Attachments" name="attachment_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Directory Name" class="oe_edit_only"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="parent_id"/>
                        <field name="department_id" options="{'no_open': True, 'no_create': True}"/>
                        <field name="res_model"/>
                        <field name="user_ids" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags" colspan="2"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_document_directory" model="ir.actions.act_window">
        <field name="name">Document Directory</field>
        <field name="path">almightycs-directory</field>
        <field name="res_model">document.directory</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Record Found
            </p>
            <p>
                Click to add a Directory.
            </p>
        </field>
    </record>

    <record id="view_document_structure_list" model="ir.ui.view">
        <field name="name">document.structure.list</field>
        <field name="model">document.directory</field>
        <field name="arch" type="xml">
            <list string="Directory Structure">
                <field name="name"/>
                <field name="res_model"/>
            </list>
        </field>
    </record>

    <!-- acs.document.tag views -->
    <record id="acs_document_tag_form" model="ir.ui.view">
        <field name="name">acs.document.tag.form</field>
        <field name="model">acs.document.tag</field>
        <field name="arch" type="xml">
            <form string="Document Tags">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" groups="base.group_no_one"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record> 

    <record id="acs_document_tag_list" model="ir.ui.view">
        <field name="name">acs.document.tag.list</field>
        <field name="model">acs.document.tag</field>
        <field name="arch" type="xml">
            <list string="Document Tags">
                <field name="name"/>
                <field name="color" groups="base.group_no_one"/>
            </list>
        </field>
    </record>

    <record id="action_acs_document_tag" model="ir.actions.act_window">
        <field name="name">Document Tags</field>
        <field name="path">almightycs-document-tag</field>
        <field name="res_model">acs.document.tag</field>
        <field name="view_id" ref="acs_document_tag_list"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Click to define a new document tag.
          </p><p>
            Create specific tags that fit your company's activities
            to better classify and analyze your documents.
            Such categories could for instance reflect your document
            structure or the different types of management you do.
          </p>
        </field>
    </record>

</odoo>