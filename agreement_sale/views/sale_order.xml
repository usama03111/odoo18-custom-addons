<odoo>

    <record id="sale_order_form_add_client_ref_and_agreement" model="ir.ui.view">
        <field name="name">sale.order.form.client.ref.and.agreement</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="payment_term_id" position="after">
<!--                <field name="client_order_ref"/>-->
                <field name="agreement_id"
                   domain="[('partner_id', '=', partner_id), ('domain', '=', 'sale')]"
                   context="{'default_partner_id': partner_id, 'default_domain': 'sale'}"/>
            </field>
        </field>
    </record>


