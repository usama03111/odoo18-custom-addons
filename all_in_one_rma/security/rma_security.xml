<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Security Groups -->
        <record id="group_rma_user" model="res.groups">
            <field name="name">RMA User</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">User can create and manage RMA requests assigned to them</field>
        </record>

        <record id="group_rma_manager" model="res.groups">
            <field name="name">RMA Manager</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('group_rma_user'))]"/>
            <field name="comment">Manager can approve/reject RMA requests and manage all RMA data</field>
        </record>

        <!-- Record Rules -->

        <!-- RMA Request Rules -->
        <record id="rma_request_rule_user" model="ir.rule">
            <field name="name">RMA Request: User Rule</field>
            <field name="model_id" ref="model_rma_request"/>
            <field name="groups" eval="[(4, ref('group_rma_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
            <field name="domain_force">[
                '|',
                ('user_id', '=', user.id),
                ('user_id', '=', False)
            ]</field>
        </record>

        <record id="rma_request_rule_manager" model="ir.rule">
            <field name="name">RMA Request: Manager Rule</field>
            <field name="model_id" ref="model_rma_request"/>
            <field name="groups" eval="[(4, ref('group_rma_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Multi-company rules -->
        <record id="rma_request_rule_company" model="ir.rule">
            <field name="name">RMA Request: Multi-company Rule</field>
            <field name="model_id" ref="model_rma_request"/>
            <field name="global" eval="1"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
        </record>

