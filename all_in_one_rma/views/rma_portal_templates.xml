<odoo>
    <template id="portal_rma_list" name="RMA List" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='content']" position="replace">
            <h2>My RMA Requests</h2>
            <a class="btn btn-primary" href="/my/rma/create">Create New RMA</a>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>RMA Ref</th>
                        <th>Order</th>
                        <th>Status</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Return Picking</th>
                        <th>Replacement Picking</th>
                        <th>Credit Note</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="rmas" t-as="rma">
                        <tr>
                            <td><t t-esc="rma.name"/></td>
                            <td><t t-esc="rma.order_id.name"/></td>
                            <td><t t-esc="rma.status"/></td>
                            <td><t t-esc="rma.type"/></td>
                            <td><t t-esc="rma.reason"/></td>
                            <td t-if="rma.return_picking_id">
                                <a t-att-href="'/web#id=%d&model=stock.picking&view_type=form' % rma.return_picking_id.id">Return Picking</a>
                            </td>
                            <td t-if="rma.replacement_picking_id">
                                <a t-att-href="'/web#id=%d&model=stock.picking&view_type=form' % rma.replacement_picking_id.id">Replacement Picking</a>
                            </td>
                            <td t-if="rma.credit_note_id">
                                <a t-att-href="'/web#id=%d&model=account.move&view_type=form' % rma.credit_note_id.id">Credit Note</a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </xpath>
    </template>

    <template id="portal_rma_create" name="Create RMA" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='content']" position="replace">
            <h2>Create RMA</h2>
            <form action="/my/rma/submit" method="post">
                <div>
                    <label>Order</label>
                    <select name="order_id">
                        <t t-foreach="orders" t-as="order">
                            <option t-att-value="order.id"><t t-esc="order.name"/></option>
                        </t>
                    </select>
                </div>
                <div>
                    <label>Return Type</label>
                    <select name="type">
                        <option value="refund">Refund</option>
                        <option value="replacement">Replacement</option>
                    </select>
                </div>
                <div>
                    <label>Reason</label>
                    <textarea name="reason"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </xpath>
    </template>
</odoo>
