<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree/List View -->
    <record id="view_rma_request_tree" model="ir.ui.view">
        <field name="name">rma.request.tree</field>
        <field name="model">rma.request</field>
        <field name="arch" type="xml">
            <list string="RMA Requests" decoration-danger="state=='rejected'" decoration-success="state=='done'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="rma_type"/>
                <field name="reason"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_rma_request_form" model="ir.ui.view">
        <field name="name">rma.request.form</field>
        <field name="model">rma.request</field>
        <field name="arch" type="xml">
            <form string="RMA Request" create="true" edit="true">
                    <header>
                        <!-- Submit visible only in draft -->
                        <button name="action_submit" type="object" string="Submit"
                                class="btn-primary"
                                invisible="state != 'draft'"/>

                        <!-- Approve visible only in submitted -->
                        <button name="action_approve" type="object" string="Approve"
                                class="btn-primary"
                                invisible="state != 'submitted'"/>

                        <!-- Reject visible until state is done -->
                        <button name="action_reset" type="object" string="Reset to Draft"
                                class="btn-secondary"
                                invisible="state == 'done'"/>

                        <!-- Process visible only in approved -->
                        <button name="action_process" type="object" string="Process"
                                class="btn-primary"
                                invisible="state != 'approved'"/>

                        <!-- Done visible only in processing -->
                        <button name="action_done" type="object" string="Done"
                                class="btn-success"
                                invisible="state != 'processing'"/>

                        <!-- Cancel visible until state is done -->
                        <button name="action_cancel" type="object" string="Cancel"
                                class="btn-secondary"
                                invisible="state == 'done'"/>

                        <!-- Statusbar -->
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,submitted,approved,processing,done,cancel"/>
                    </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_warehouse_in" type="object"
                                string="RMA IN" class="oe_stat_button" icon="fa-rotate-left">
                            <field string="Returns" name="rma_count" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="picking_id" readonly="state != 'draft'"/>
                            <field name="sale_id" readonly="state != 'draft'"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="state != 'draft'" groups="base.group_multi_company"/>
                        </group>
                        <group>
<!--                            <field name="picking_type" readonly="state != 'draft'"/>-->
<!--                            <field name="location_dest_id" readonly="state != 'draft'"/>-->
                            <field name="reason" readonly="state != 'draft'"/>
                            <field name="rma_type" readonly="state != 'draft'"/>
                            <field name="priority" readonly="state != 'draft'"/>
                            <field name="expected_resolution_date" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="RMA Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id" readonly="parent.state != 'draft'"/>
                                    <field name="qty" readonly="parent.state != 'draft'"/>
                                    <field name="uom_id" readonly="parent.state != 'draft'"/>
<!--                                    <field name="price_unit"/>-->
<!--                                    <field name="subtotal" readonly="1"/>-->
                                </list>
                            </field>
                        </page>
                        <page string="Reason Note">
                            <group>
                                <field name="reason_note"/>
                            </group>
                        </page>

                        <page string="Internal Notes">
                            <field name="note_internal"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_rma_request_pivot" model="ir.ui.view">
        <field name="name">rma.request.pivot</field>
        <field name="model">rma.request</field>
        <field name="arch" type="xml">
            <pivot string="RMA Analysis">
                <field name="partner_id" type="row"/>
                <field name="rma_type" type="row"/>
                <field name="state" type="col"/>
                <field name="priority" type="col"/>
                <field name="reason" type="row"/>
                <field name="create_date" interval="month" type="col"/>
                <!--                <field name="id" type="measure"/>-->
            </pivot>
        </field>
    </record>

    <!--    Search view-->
    <record id="view_rma_request_search" model="ir.ui.view">
        <field name="name">rma.request.search</field>
        <field name="model">rma.request</field>
        <field name="arch" type="xml">
            <search>
                <!-- Quick search fields -->
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_id"/>
                <field name="user_id"/>
                <field name="company_id"/>

                <!-- State filters -->
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state','=','approved')]"/>
                <filter string="Processing" name="filter_processing" domain="[('state','=','processing')]"/>
                <filter string="Done" name="filter_done" domain="[('state','=','done')]"/>
                <filter string="Rejected" name="filter_rejected" domain="[('state','=','rejected')]"/>
                <filter string="Cancelled" name="filter_cancel" domain="[('state','=','cancel')]"/>

                <!-- Group By section -->
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by':'partner_id'}"/>
                    <filter string="Salesperson" name="group_user" context="{'group_by':'user_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by':'company_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>


    <!-- Action + Menu -->
    <record id="action_rma_request" model="ir.actions.act_window">
        <field name="name">RMA Requests</field>
        <field name="res_model">rma.request</field>
        <field name="view_mode">list,form,pivot,search</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first RMA request
            </p>
        </field>
    </record>


    <menuitem id="menu_rma_root" name="RMA" sequence="10"/>
    <menuitem id="menu_rma_request" name="RMA Requests"
              parent="menu_rma_root" action="action_rma_request" sequence="10"/>


</odoo>
