<odoo>
    <record id="view_crm_lead_form_inherit_social" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.social</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add after the website field -->
            <xpath expr="//group/group/field[@name='website']" position="after">
                <field name="facebook" widget="url" placeholder="e.g. https://www.facebook.com/yourpage"/>
                <field name="instagram" widget="url" placeholder="e.g. https://www.instagram.com/yourprofile"/>
                <field name="tiktok" widget="url" placeholder="e.g. https://www.tiktok.com/@yourprofile"/>

            </xpath>
            <xpath expr="//group/group[@name='lead_info']" position="inside">
                <field name="industry_type" placeholder="e.g. Manufacturing / IT / Retail"/>
                <field name="linkedin" widget="url" placeholder="e.g. https://www.linkedin.com/in/yourprofile"/>

            </xpath>
        </field>
    </record>
</odoo>
