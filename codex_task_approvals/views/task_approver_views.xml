<?xml version="1.0" encoding="UTF-8"?>
<odoo>


    <record id="view_task_approver_list" model="ir.ui.view">
        <field name="name">task.approver.list</field>
        <field name="model">task.approver</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="approval_minimum"/>
                <field name="approver_sequence"/>
                <field name="automated_sequence"/>
            </list>
        </field>
    </record>

    <record id="view_task_approver_form" model="ir.ui.view">
        <field name="name">task.approver.form</field>
        <field name="model">task.approver</field>
        <field name="arch" type="xml">
            <form string="Task Approval Rule">
                <sheet>
                     <div class="oe_title">
                        <label for="name" string="Task Request Type"/>
                        <h1>
                            <field name="name" placeholder="e.g. Type"/>
                        </h1>
                    </div>
                    <group string="Task Approvers" name="approvers">
                        <separator colspan="2"/>
                        <field name="approver_ids"/>
                        <field name="approver_sequence" invisible="approval_minimum == 0"/>
                        <field name="approval_minimum"/>

                        <field name="invalid_minimum" invisible="1"/>
                        <div class="text-warning" colspan="2" invisible="not invalid_minimum">
                            <span class="fa fa-warning" title="Invalid minimum approvals"/>
                            <field name="invalid_minimum_warning" nolabel="1"/>
                        </div>
                    </group>
                    <group string="Rejection Type">
                        <group>
                            <field name="to_approve_previous_approver"   invisible="on_rejection_approval_restart == True"/>
                        </group>
                        <group>
                            <field name="on_rejection_approval_restart"  invisible="to_approve_previous_approver == True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_task_approver" model="ir.actions.act_window">
        <field name="name">Task Approval Rules</field>
        <field name="res_model">task.approver</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Configure rules for who should approve tasks and in what order.</p>
        </field>
    </record>

    <!-- Menu -->
<!--    <menuitem id="menu_task_approval_root" name="Task Approvals" sequence="10"/>-->
<!--    <menuitem id="menu_task_approval_config" name="Approval Rules" parent="menu_task_approval_root" sequence="10"-->
<!--              action="action_task_approver"/>-->
    <menuitem id="menu_task_approval_config_sub" name="Task Approval" parent="project.menu_project_config" sequence="10"
              action="action_task_approver"/>

</odoo>
