<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_inherit_approval" model="ir.ui.view">
        <field name="name">project.task.inherit.approval</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//h1[@class='d-flex justify-content-between align-items-center']" position="before">
                <div class="oe_title">
                    <h1>
                        <field name="reference"/>
                    </h1>
                </div>
            </xpath>

            <xpath expr="//field[@name='state' and @widget='project_task_state_selection']" position="attributes">
                <attribute name="readonly">approver_id != False</attribute>
            </xpath>

            <xpath expr="//header/field[@name='stage_id']" position="attributes">
                <attribute name="invisible">state in ['01_in_progress','pending','03_approved', '1_canceled']
                </attribute>
            </xpath>

            <!--Approval field after Responsible-->
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="approver_id" readonly="state in ['03_approved', '1_canceled', '1_done', False]"/>
            </xpath>

            <!-- Inject Buttons in header -->
            <xpath expr="//header" position="inside">
                <field name="user_status" invisible="1"/>
                <button name="send_for_approvals" string="Send For Approval" type="object"
                        invisible="not approver_ids or state != '01_in_progress'" class="btn-primary"/>
                <button name="action_approve" string="Approve" type="object" class="btn btn-success"
                        invisible="state in ['1_done', '1_canceled'] or user_status != 'pending'"/>
                <!--                <button name="action_cancel" string="Cancel" type="object" class="btn btn-danger"-->
                <!--                        invisible="state in ['01_in_progress', '1_canceled'] or user_status != 'pending'"/> -->
                <button name="%(cancel_wizard_reason_action_view_task)d" string="Cancel" type="action"
                        class="btn btn-danger"
                        invisible="state in ['01_in_progress', '1_canceled'] or user_status != 'pending'"/>
            </xpath>

            <!-- Approval status field (as statusbar) -->
            <xpath expr="//field[@name='stage_id']" position="after">
                <field name="state" widget="statusbar"
                       statusbar_visible="01_in_progress,pending,03_approved,1_done"
                       invisible="state == '1_done'"/>
            </xpath>

            <!-- Approver Tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Approver(s)" name="approvers" invisible="not approver_id">
                    <field name="approver_ids" mode="list" readonly="state != '01_in_progress'">
                        <list editable="bottom" decoration-success="status=='approved'"
                              decoration-warning="status in ['pending', 'waiting']"
                              decoration-danger="status=='cancel'" no_open="1">
                            <field name="existing_request_user_ids" column_invisible="True"/>
                            <field name="sequence" column_invisible="True"/>
                            <field name="can_edit" column_invisible="True"/>
                            <field name="can_edit_user_id" column_invisible="True"/>
                            <field name="user_id" string="Approver"
                                   readonly="not can_edit_user_id or status != 'new'" force_save="1"/>
                            <field name="required" readonly="not can_edit" force_save="1"/>
                            <field name="status"/>
                            <field name="company_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
                <page string="Rejection Reason" name="rejection">
                    <field name="rejection_reason" readonly="1">
                    </field>
                </page>
            </xpath>

        </field>
    </record>


</odoo>

