<templates xml:space="preserve">
    <t t-inherit="mail.AttachmentList" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o-mail-AttachmentCard-aside')]" position="inside">
            <button t-if="env.inComposer and attachment and attachment.downloadUrl" class="btn d-flex align-items-center justify-content-center w-100 h-100 rounded-0"
                    t-attf-class="bg-300"
                    t-att-data-download-url="attachment.downloadUrl"
                    title="Download">
                <i class="fa fa-download" role="img" aria-label="Download"/>
            </button>
        </xpath>
    </t>
</templates> 