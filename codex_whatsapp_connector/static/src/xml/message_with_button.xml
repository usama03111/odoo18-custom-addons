<templates xml:space="preserve">
<!--  Append WhatsApp button inside Composer main actions  -->
    <t t-inherit="mail.Composer.actions" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o-mail-Composer-mainActions')]" position="inside">
            <t t-if="thread and thread.model == 'discuss.channel'">
                <button type="button" class="btn btn-secondary o_whatsapp_send_btn ms-1" title="Send in WhatsApp"
                        t-att-data-thread-model="thread and thread.model or ''"
                        t-att-data-thread-id="thread and thread.id or ''">
                    <i class="fa fa-whatsapp me-1 text-success fs-4"/>
                </button>
            </t>
        </xpath>
    </t>
</templates>