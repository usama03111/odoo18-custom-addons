<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_server_action_form_whatsapp" model="ir.ui.view">
        <field name="name">ir.actions.server.view.form.whatsapp</field>
        <field name="model">ir.actions.server</field>
        <field name="inherit_id" ref="base.view_server_action_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="wa_template_id" invisible="state != 'whatsapp'" required="state == 'whatsapp'"/>
            </xpath>
        </field>
    </record>
</odoo>
