<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_whatsapp_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.whatsapp</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="0"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="WhatsApp" string="WhatsApp" name="whatsapp_settings" logo="/codex_whatsapp_connector/static/description/whatsapp.png">
                    <block title="WhatsApp Configuration" name="whatsapp_configuration">
                        <setting string="Show WhatsApp Button On Models" help="Select the models where the WhatsApp button should appear in the chatter. If left empty, the button will be visible for all models.">
                            <div class="row">
                                <div class="col-12">
                                    <field name="wa_button_models_ids" widget="many2many_tags"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
