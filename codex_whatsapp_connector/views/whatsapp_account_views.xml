<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="whatsapp_account_view_form" model="ir.ui.view">
        <field name="name">whatsapp.account.view.form</field>
        <field name="model">whatsapp.account</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Business Account">
                <header>
                    <button name="button_test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <button name="button_sync_whatsapp_account_templates" string="Sync Templates" type="object"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_templates" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="templates_count" widget="statinfo" string="Templates"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. My Business"/></h1>
                    </div>
                    <group>
                        <group name="credentials" string="Credentials">
                            <field name="account_uid"/>
                            <field name="phone_uid"/>
                            <field name="app_uid"/>
                            <field name="app_secret" password="True"/>
                            <field name="token" password="True"/>
                        </group>
                        <group name="configuration" string="Configuration">
                            <field name="webhook_verify_token" readonly="1"/>
                            <field name="callback_url" widget="CopyClipboardChar"/>
                            <field name="notify_user_ids" widget="many2many_tags"/>
                            <field name="allowed_company_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="whatsapp_account_view_tree" model="ir.ui.view">
        <field name="name">whatsapp.account.view.tree</field>
        <field name="model">whatsapp.account</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Business Accounts">
                <field name="name"/>
                <field name="phone_uid"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="whatsapp_account_action" model="ir.actions.act_window">
        <field name="name">WhatsApp Business Accounts</field>
        <field name="res_model">whatsapp.account</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new WhatsApp Business Account
            </p>
        </field>
    </record>
</odoo>
