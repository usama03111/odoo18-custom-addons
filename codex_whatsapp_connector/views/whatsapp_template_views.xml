<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="whatsapp_template_view_form" model="ir.ui.view">
        <field name="name">whatsapp.template.view.form</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Template">
                <header>
                    <button name="button_submit_template" string="Submit to Meta" type="object" class="btn-primary" invisible="status not in ('draft', 'rejected')"/>
                    <button name="button_sync_template" string="Sync Status" type="object" invisible="status == 'draft'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="wa_account_id" required="1"/>
                            <field name="template_type"/>
                            <field name="lang_code"/>
                        </group>
                        <group>
                            <field name="model_id"/>
                            <field name="phone_field" invisible="not model_id"/>
                            <field name="quality" readonly="1" invisible="status == 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <group string="Header">
                                <field name="header_type"/>
                                <field name="header_text" invisible="header_type != 'text'"/>
                                <field name="header_attachment_ids" widget="many2many_binary" invisible="header_type not in ('image', 'video', 'document')"/>
                            </group>
                            <group string="Body">
                                <field name="body" placeholder="Hello {{1}}, your order {{2}} is ready."/>
                            </group>
                            <group string="Footer">
                                <field name="footer_text"/>
                            </group>
                            <group string="Buttons">
                                <field name="button_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="button_type"/>
                                        <field name="name"/>
                                        <field name="call_number" invisible="button_type != 'phone_number'"/>
                                        <field name="website_url" invisible="button_type != 'url'"/>
                                        <field name="url_type" invisible="button_type != 'url'"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Variables" name="variables">
                            <field name="variable_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="line_type"/>
                                    <field name="field_type"/>
                                    <field name="demo_value"/>
                                    <field name="field_name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="whatsapp_template_view_tree" model="ir.ui.view">
        <field name="name">whatsapp.template.view.list</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Templates">
                <field name="name"/>
                <field name="wa_account_id"/>
                <field name="status" widget="badge" decoration-success="status == 'approved'" decoration-info="status == 'pending'" decoration-danger="status == 'rejected' or status == 'disabled'"/>
<!--                <field name="update_time" widget="date"/>-->
            </list>
        </field>
    </record>
    
    <record id="whatsapp_template_action" model="ir.actions.act_window">
        <field name="name">WhatsApp Templates</field>
        <field name="res_model">whatsapp.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
