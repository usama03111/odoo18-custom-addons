<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.foodics</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_login_documents']" position="after">
                <div class="col-12 col-lg-6 o_setting_box" id="foodics_approval">
                    <div class="o_setting_left_pane">
                    </div>
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Foodics Configuration</span>
                        <div class="text-muted">
                            API Credentials
                        </div>
                        <div class="content-group mt16">
                            <div class="row mt16">
                                <label string="Client ID" for="foodics_client_id" class="col-lg-3 o_light_label"/>
                                <field name="foodics_client_id"/>
                            </div>
                            <div class="row mt16">
                                <label string="Environment" for="foodics_environment" class="col-lg-3 o_light_label"/>
                                <field name="foodics_environment"/>
                                <div class="row mt16">
                                <label string="Redirect URI" for="foodics_redirect_uri" class="col-lg-3 o_light_label"/>
                                <field name="foodics_redirect_uri" placeholder="e.g. https://zad.knowledge-bonds.com/web/login"/>
                            </div>
                        </div>
                            <div class="row mt16">
                                <label string="Client Secret" for="foodics_client_secret" class="col-lg-3 o_light_label"/>
                                <field name="foodics_client_secret"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
