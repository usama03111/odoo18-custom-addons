<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ✅ A4 PAPER FORMAT (FULL PAGE, NO TOP GAP) -->
    <record id="paperformat_gatepass_a4_full" model="report.paperformat">
        <field name="name">Gate Pass A4 Full Page</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>

        <!-- 🔴 THESE REMOVE TOP SPACE -->
        <field name="margin_top">0</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
        <field name="css_margins" eval="True"/>

        <!-- SIDE & BOTTOM MARGINS -->
        <field name="margin_bottom">6</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>

        <field name="dpi">90</field>
    </record>

    <!-- ✅ GATE PASS REPORT ACTION (LINKED TO A4 FORMAT) -->
    <record id="action_gate_pass_report" model="ir.actions.report">
        <field name="name">Gate Pass</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gatepass_pdf_report.gate_pass_template</field>
        <field name="report_file">gatepass_pdf_report.gate_pass_template</field>
        <field name="print_report_name">'Gate Pass - %s' % (object.name)</field>

        <!-- 🔴 THIS IS THE REAL FIX -->
        <field name="paperformat_id" ref="gatepass_pdf_report.paperformat_gatepass_a4_full"/>
    </record>

</odoo>
