<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="gate_pass_template">

        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">

                    <div class="page"
                         style="padding:4mm 6mm;background:#ffffff;box-sizing:border-box;overflow:hidden;position:relative;">

                        <!-- HEADER -->
                        <div style="width:100%;background:#2d4c7c;padding:8px 6px;text-align:center;color:white;border-radius:4px;margin-bottom:6px;font-weight:bold;">
                            <div style="font-size:24px;font-weight:900;text-transform:uppercase;">Gate Pass</div>
                        </div>

                        <!-- COMPANY HEADER -->
                        <!-- HEADER (DIV BASED – NO BORDER GUARANTEED) -->
                        <div style="
    width:100%;
    display:block;
    margin-bottom:6px;
    font-weight:bold;
">

                            <!-- LEFT LOGO -->
                            <div style="
        width:30%;
        float:left;
        text-align:left;
    ">
                                <img t-att-src="'/gatepass_pdf_report/static/src/img/logo_left.png'"
                                     style="width:110px; height:auto; border:none; outline:none;"/>
                            </div>

                            <!-- CENTER INFO -->
                            <div style="
        width:40%;
        float:left;
        text-align:center;
    ">
                                <div style="font-size:20px; font-weight:900; text-transform:uppercase; color:#2d4c7c;">
                                    AL HUSSAIN SOAP &amp; CHEMICAL<br/>INDUSTRY
                                </div>
                                <div style="font-size:11px; margin-top:2px;">
                                    Katlang District Mardan, KPK, Pakistan
                                </div>
                                <div style="font-size:11px;">
                                    Phone #: 0937-575444, 0937-575390
                                </div>
                                <div style="font-size:11px;">
                                    Cell #: 0332-8311800, 0343-8311800, 0344-9200520
                                </div>
                                <div style="font-size:11px; margin-top:2px; color:#2d4c7c;">
                                    alhussainsoapfactory800@gmail.com
                                </div>
                            </div>

                            <!-- RIGHT LOGO -->
                            <div style="
        width:30%;
        float:right;
        text-align:right;
    ">
                                <img t-att-src="'/gatepass_pdf_report/static/src/img/logo_right.png'"
                                     style="width:110px; height:auto; border:none; outline:none;"/>
                            </div>

                            <!-- CLEAR FLOAT -->
                            <div style="clear:both;"></div>

                        </div>

                        <!-- INFO -->
                        <div style="padding:6px;border:1px solid #bfc5d1;background:#f3f6fa;margin-bottom:8px;font-size:13px;border-left:4px solid #2d4c7c;font-weight:bold;">
                            Gate Pass #:
                            <t t-esc="o.name"/>
                            <span style="float:right;">
                                Time:
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%I:%M %p')"/>
                            </span>
                            <div>Date:
                                <t t-esc="o.invoice_date"/>
                            </div>
                        </div>

                        <!-- CUSTOMER DETAILS TABLE -->
                        <table style="width:100%; border-collapse:collapse; margin-bottom:6px;
              font-size:12px; border:1px solid #b0b7c4; font-weight:bold;">

                            <tr>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7; width:20%;">
                                    Customer Name
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px; width:30%;">
                                    <t t-esc="o.partner_id.name"/>
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7; width:20%;">
                                    Contact #
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px; width:30%;">
                                    <t t-esc="o.partner_id.phone or 'N/A'"/>
                                </td>
                            </tr>

                            <tr>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7;">
                                    Shipped To
                                </td>
                                <td colspan="3" style="border:1px solid #b0b7c4; padding:6px;">
                                    <t t-esc="o.sub_customer_id.contact_address or 'N/A'"/>
                                </td>
                            </tr>

                            <tr>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7;">
                                    Driver Name
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px;">
                                    <t t-esc="o.driver_name or 'N/A'"/>
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7;">
                                    Driver Contact
                                </td>
                                <td style="border:1px solid #b0b7c4; padding:6px;">
                                    <t t-esc="o.driver_contact or 'N/A'"/>
                                </td>
                            </tr>

                            <tr>
                                <td style="border:1px solid #b0b7c4; padding:6px; background:#eef2f7;">
                                    Vehicle Number
                                </td>
                                <td colspan="3" style="border:1px solid #b0b7c4; padding:6px;">
                                    <t t-esc="o.vehicle_no or 'N/A'"/>
                                </td>
                            </tr>

                        </table>


                        <!-- TITLE -->
                        <h2 style="text-align:center;font-weight:900;color:#2d4c7c;margin-bottom:6px;">
                            AUTHORIZED MATERIAL MOVEMENT
                        </h2>

                        <!-- MATERIAL TABLE -->
                        <table style="width:100%;border-collapse:collapse;font-size:13px;font-weight:bold;">
                            <thead>
                                <tr style="background:#2d4c7c;color:white;">
                                    <th style="border:1px solid #1d355e;padding:6px;width:8%;">Sr No</th>
                                    <th style="border:1px solid #1d355e;padding:6px;width:62%;">Product</th>
                                    <th style="border:1px solid #1d355e;padding:6px;width:30%;">Quantity</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <t t-foreach="o.invoice_line_ids" t-as="l">

                                    <!-- SECTION -->
                                    <tr t-if="l.display_type == 'line_section'">
                                        <td colspan="3"
                                            style="border:1px solid #1d355e;background:#dde3ee;padding:6px;">
                                            <t t-esc="l.name"/>
                                        </td>
                                    </tr>

                                    <!-- NOTE -->
                                    <tr t-elif="l.display_type == 'line_note'">
                                        <td colspan="3" style="border:1px solid #c5cad3;font-style:italic;padding:6px;">
                                            <t t-esc="l.name"/>
                                        </td>
                                    </tr>

                                    <!-- PRODUCT (EXCLUDE SERVICES) -->
                                    <tr t-else=""
                                        t-if="l.product_id and l.product_id.type != 'service'">

                                        <td style="border:1px solid #c5cad3;text-align:center;padding:6px;">
                                            <t t-set="idx" t-value="idx + 1"/>
                                            <t t-esc="idx"/>
                                        </td>

                                        <td style="border:1px solid #c5cad3;padding:6px;">
                                            <div>
                                                <t t-esc="l.product_id.display_name"/>
                                            </div>
                                            <t t-if="l.name and l.name != l.product_id.display_name">
                                                <div style="font-style:italic;font-size:12px;color:#555;">
                                                    <t t-esc="l.name"/>
                                                </div>
                                            </t>
                                        </td>

                                        <td style="border:1px solid #c5cad3;text-align:center;padding:6px;">
                                            <t t-esc="l.quantity or ''"/>
                                        </td>
                                    </tr>

                                </t>
                            </tbody>

                        </table>

                        <div style="height:60px;"></div>
                        <!-- SIGNATURES (NO TABLE - NO BORDER GUARANTEED) -->
                        <div style="width:100%; margin-top:18px; font-size:12px; font-weight:bold; text-align:center;">

                            <div style="width:33%; display:inline-block; vertical-align:top;  border:none; ">
                                _________________________
                                <br/>
                                Prepared By
                            </div>

                            <div style=" width:33%;display:inline-block;vertical-align:top; border:none;">
                                _________________________
                                <br/>
                                Approved By
                            </div>

                            <div style="width:33%;display:inline-block;vertical-align:top; border:none; ">
                                _________________________
                                <br/>
                                Received By
                            </div>

                        </div>


                    </div>
                    <!-- WARNING -->
                    <div style="margin-top:10px;padding:8px;border:1px solid #2d4c7c;background:#eef2f7;text-align:center;font-size:12px;font-weight:bold;">
                        This gate pass is valid only for the listed items. Unauthorized movement is strictly
                        prohibited.
                    </div>


                    <!-- FOOTER -->
                    <div style="margin-top:6px;text-align:center;font-size:10px;color:#777;">

                        <strong>Software by NerithonX Technologies (Pvt.) Ltd. | www.nerithonx.com</strong>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
