<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_move_form_gate_pass" model="ir.ui.view">
        <field name="name">account.move.form.gate.pass</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Gate Pass button: visible only for Customer Invoices -->
            <xpath expr="//header/button[@name='action_print_pdf']" position="after">
                <button
                        name="action_print_gate_pass"
                        type="object"
                        string="Gate Pass"
                        class="btn btn-primary"
                        invisible="state in ('draft','cancel') or move_type not in ('out_invoice','out_refund') or not company_id.gatepass_enabled"/>
            </xpath>

        </field>
    </record>

</odoo>
