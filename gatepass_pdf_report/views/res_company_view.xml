<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_company_form_gatepass_settings" model="ir.ui.view">
        <field name="name">res.company.form.gatepass.settings</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <!-- Add a simple toggle inside the Company form -->
            <xpath expr="//sheet" position="inside">
                <group string="Gate Pass">
                    <field name="gatepass_enabled"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
