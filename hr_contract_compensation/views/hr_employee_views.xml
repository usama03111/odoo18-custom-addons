<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Employee Form View -->
    <record id="view_employee_form_attachment" model="ir.ui.view">
        <field name="name">hr.employee.form.attachment</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='coach_id']" position="after">
                <field name="joining_date"/>

            </xpath>
            <xpath expr="//field[@name='work_email']" position="before">
                <field name="emp_sequence_number"/>
                <field name="expiry_date"/>
                <field name="employee_attachment" filename="employee_attachment_name"/>
                <field name="employee_attachment_name" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='personal_information']/group" position="inside">
                <group string="Salary Certification">
                    <field name="salary_cert_addressee"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Extend Employee Kanban View -->
    <record id="hr_kanban_view_employees_attachment" model="ir.ui.view">
        <field name="name">hr.employee.kanban.attachment</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <xpath expr="//templates" position="before">
                <field name="employee_attachment"/>
                <field name="employee_attachment_name"/>
                <field name="expiry_date"/>
            </xpath>

            <xpath expr="//field[@name='category_ids']" position="after">
                <div t-if="record.employee_attachment.raw_value" class="mt-1">
                    <i class="fa fa-paperclip me-1"/>
                    <field name="employee_attachment" widget="binary" filename="employee_attachment_name"/>
                </div>

                <div t-if="record.expiry_date.raw_value">
                    <strong>QID EXPIRY:</strong>
                    <t t-esc="record.expiry_date.value"/>
                </div>
            </xpath>

        </field>
    </record>

    <record id="view_employee_form_inherit_category" model="ir.ui.view">
    <field name="name">hr.employee.form.inherit.category</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">10</field>
    <field name="arch" type="xml">

        <xpath expr="//field[@name='work_email']" position="before">
            <field name="category_ids" widget="many2many_tags" position="move"/>
        </xpath>

    </field>
</record>
</odoo>
