    <odoo>
    <data noupdate="1">
        <!-- Custom Group -->
        <record id="group_employee_private_access" model="res.groups">
            <field name="name">Employee Private Access</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>
        <record id="group_employee_hide_access" model="res.groups">
            <field name="name">Employee Menus Access</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>
    </data>


    <!-- Hide Departments menu -->
    <record id="hr.menu_hr_department_kanban" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('hr_employee_access.group_employee_hide_access')])]"/>
    </record>

    <!-- Hide Reporting menu -->
    <record id="hr.hr_menu_hr_reports" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('hr_employee_access.group_employee_hide_access')])]"/>
    </record>

    <!-- Hide Configuration menu -->
    <record id="hr.menu_human_resources_configuration" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('hr_employee_access.group_employee_hide_access')])]"/>
    </record>


</odoo>
