<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="hr_employee_leave_list_template" inherit_id="portal.portal_sidebar">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <t t-if="page_name == 'employee_leave_list'">
                <section style="background-color: #eee;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">
                            <i class="fa fa-calendar-check me-1"></i>
                            Attendance Records
                        </h5>

                        <form action="/employee/attendance/toggle" method="post">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>

                            <button type="submit"
                                    t-attf-class="btn btn-{{ attendance_state == 'checked_in' and 'warning' or 'success' }}">
                                <t t-if="attendance_state == 'checked_in'">
                                    <i class="fa fa-sign-out me-1"></i>
                                    Check Out
                                </t>
                                <t t-else="">
                                    <i class="fa fa-sign-in me-1"></i>
                                    Check In
                                </t>
                            </button>
                        </form>
                    </div>

                    <div class="col-auto">
                        <div class="card mb-4">
                            <div class="card-body">
                                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                                    <div class="table-responsive">
                                        <table class="table align-middle mb-0 table-hover">
                                            <thead class="table-primary text-center text-uppercase">
                                                <tr>
                                                    <th>Employee name</th>
                                                    <th>Check In</th>
                                                    <th>Check Out</th>
                                                    <th>Worked Hours</th>
                                                    <th>Extra Hours</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody class="text-center">
                                                <t t-foreach="records" t-as="doc">
                                                    <tr>
                                                        <td>
                                                            <span t-field="doc.employee_id.name"/>
                                                        </td>
                                                        <td>
                                                            <span t-field="doc.check_in"/>
                                                        </td>
                                                        <td>
                                                            <span t-field="doc.check_out"/>
                                                        </td>
                                                        <td>
                                                            <span t-field="doc.worked_hours" t-options='{"widget": "float_time"}'/>

                                                        </td>
                                                        <td>
                                                            <span t-field="doc.overtime_hours" t-options='{"widget": "float_time"}'/>
                                                        </td>
                                                        <td>
                                                            <a t-attf-href="/employee/leave/{{ doc.id }}"
                                                               class="text-primary fw-bold">
                                                                View
                                                            </a>
                                                        </td>
                                                    </tr>
                                                </t>

                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </t>
        </xpath>
    </template>

    <template id="inherit_task_detail_breadcrumbs" inherit_id="portal.portal_breadcrumbs"
              name="Task Detail Breadcrumbs">
        <xpath expr="//ol[contains(@class, 'breadcrumb')]" position="inside">
            <!-- List View -->
            <li t-if="page_name == 'employee_leave_list'"
                class="breadcrumb-item active"
                aria-current="page">
                Leaves
            </li>

            <!-- Form View: Leaves link -->
            <li t-if="page_name == 'employee_leave_form'"
                class="breadcrumb-item">
                <a href="/employee/leaves">Leaves</a>
            </li>

            <!-- Form View: Employee Name -->
            <li t-if="page_name == 'employee_leave_form'"
                class="breadcrumb-item active"
                aria-current="page">
                <span t-esc="attendance.employee_id.name"/>
            </li>

        </xpath>
    </template>


    <template id="hr_employee_leave_form_template" inherit_id="portal.portal_sidebar">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <t t-if="page_name == 'employee_leave_form'">

                <!-- Main Card Container -->
                <div class="card shadow-lg border-0 rounded-4 my-4">

                    <!-- Header -->
                    <div class="card-header bg-gradient-primary text-white">
                        <h4 class="mb-0">
                            <i class="fa fa-user-clock me-2"></i>
                            Attendance Details
                        </h4>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body">

                        <!-- Employee Row -->
                        <div class="row align-items-center p-3 mb-3 border rounded hover-shadow">
                            <div class="col-md-4 text-muted fw-semibold">
                                <i class="fa fa-user me-1"></i>
                                Employee
                            </div>
                            <div class="col-md-8">
                                <span t-field="attendance.employee_id.name" class="fw-bold fs-6"/>
                            </div>
                        </div>

                        <!-- Check In Row -->
                        <div class="row align-items-center p-3 mb-3 border rounded hover-shadow">
                            <div class="col-md-4 text-muted fw-semibold">
                                <i class="fa fa-sign-in-alt me-1"></i>
                                Check In
                            </div>
                            <div class="col-md-8">
                                <span t-field="attendance.check_in" class="fs-6"/>
                            </div>
                        </div>

                        <!-- Check Out Row -->
                        <div class="row align-items-center p-3 mb-3 border rounded hover-shadow">
                            <div class="col-md-4 text-muted fw-semibold">
                                <i class="fa fa-sign-out-alt me-1"></i>
                                Check Out
                            </div>
                            <div class="col-md-8">
                                <span t-field="attendance.check_out" class="fs-6"/>
                            </div>
                        </div>

                        <!-- Worked Hours Row -->
                        <div class="row align-items-center p-3 mb-3 border rounded hover-shadow">
                            <div class="col-md-4 text-muted fw-semibold">
                                <i class="fa fa-clock me-1"></i>
                                Worked Hours
                            </div>
                            <div class="col-md-8">
                                <span t-field="attendance.worked_hours" class="badge bg-success fs-6" t-options='{"widget": "float_time"}'/>
                            </div>
                        </div>

                        <!-- Overtime Row -->
                        <div class="row align-items-center p-3 mb-3 border rounded hover-shadow"
                             t-if="attendance.overtime_hours">
                            <div class="col-md-4 text-muted fw-semibold">
                                <i class="fa fa-hourglass-half me-1"></i>
                                Overtime
                            </div>
                            <div class="col-md-8">
                                <span t-field="attendance.overtime_hours" class="badge bg-warning fs-6" t-options='{"widget": "float_time"}'/>
                            </div>
                        </div>

                    </div>

                    <!-- Footer -->
                    <div class="card-footer text-end bg-light">
                        <a href="/employee/leaves" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-1"></i>
                            Back to List
                        </a>
                    </div>

                </div>

            </t>
        </xpath>
    </template>


</odoo>
