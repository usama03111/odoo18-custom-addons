<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="0">
		<!-- New group under Employees category -->
		<record id="group_hr_employee_self_service" model="res.groups">
			<field name="name">User: Manage Own profile</field>
			<field name="comment">Users with this group can read and edit only their own employee record.</field>
		</record>

		<!-- Record rules: allow read/write on own employee record only -->
		<record id="hr_employee_rule_self_read_write" model="ir.rule">
			<field name="name">Employee: self read/write</field>
			<field name="model_id" ref="hr.model_hr_employee"/>
			<field name="groups" eval="[(4, ref('hr_employee_profile_self_service.group_hr_employee_self_service'))]"/>
			<field name="domain_force">[( 'user_id', '=', user.id )]</field>
		</record>
	</data>
</odoo>