<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inherit the multi-allocation wizard form to:
        1. Use type_request_unit (computed) instead of request_unit (related) for Days/Hours label,
           so the label correctly shows "Hours" when the accrual plan is hour-based.
        2. Hide the Duration field entirely when allocation_type == 'accrual', matching the
           single-employee hr.leave.allocation form behaviour.
    -->
    <record id="hr_leave_allocation_generate_multi_wizard_view_form_fix"
            model="ir.ui.view">
        <field name="model">hr.leave.allocation.generate.multi.wizard</field>
        <field name="inherit_id"
               ref="hr_holidays.hr_leave_allocation_generate_multi_wizard_view_form"/>
        <field name="arch" type="xml">

            <!-- Expose type_request_unit as an invisible field so the view can reference it -->
            <field name="request_unit" position="after">
                <field name="type_request_unit" invisible="1"/>
            </field>

            <!-- Show Duration label for both regular and accrual (simulation fills it) -->
            <xpath expr="//div[@class='o_td_label'][label[@for='duration']]" position="replace">
                <div class="o_td_label">
                    <label for="duration"/>
                </div>
            </xpath>

            <!-- Always show Duration; use type_request_unit for the Days/Hours label -->
            <div name="duration_display" position="replace">
                <div name="duration_display">
                    <field name="duration" nolabel="1" style="width: 5rem;"/>
                    <span class="ml8" invisible="type_request_unit == 'hour'">Days</span>
                    <span class="ml8" invisible="type_request_unit != 'hour'">Hours</span>
                </div>
            </div>

        </field>
    </record>
</odoo>
