<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customizing the hr.payslip form view to include additional
    fields after the 'paid' field. -->
    <record model="ir.ui.view" id="hr_payslip_view_form">
        <field name="name">hr.payslip.view.form.inherit.hr.payroll.account.community</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id"
               ref="hr_payroll_community.hr_payslip_view_form"/>
        <field name="arch" type="xml">
            <field name="paid" position="after">
                <field name="date" readonly="state != 'draft'"/>
                <field name="journal_id" required="1" readonly="state != 'draft'"/>
                <field name="move_id" readonly="1"/>
            </field>
            <xpath expr="//sheet" position="inside">
                <group string="Extra Salary Info">
                    <group>
                        <label for="allowance"/>
                        <div class="o_row mw-50">
                            <field name="allowance" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                            <div class="mb-3">/ month</div>
                        </div>
                    </group>
                    <group>
                        <label for="deduction"/>
                        <div class="o_row mw-50">
                            <field name="deduction" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                            <div class="mb-3">/ month</div>
                        </div>
                    </group>
                    <group>
                        <label for="bonus"/>
                        <div class="o_row mw-50">
                            <field name="bonus" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                            <div class="mb-3">/ month</div>
                        </div>
                    </group>
                </group>
                <group string="Description Area">
                        <field name="note" placeholder="Enter Your Description"
                                options="{'collaborative': true,'resizable':true ,}"/>
                </group>
            </xpath>

        </field>
    </record>

    <!--Inherit the search view and apply group through departments-->
    <record id="hr_payslip_search_inherit_department" model="ir.ui.view">
        <field name="name">hr.payslip.search.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id"
               ref="hr_payroll_community.hr_payslip_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter string="Departments"
                        name="department_id"
                        context="{'group_by':'department_id'}"/>
            </xpath>
        </field>
    </record>


    <!--This pivot view for reporting-->
    <record id="view_hr_payslip_pivot_custom" model="ir.ui.view">
        <field name="name">hr.payslip.pivot.custom</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <pivot string="Payslip Pivot">
                <field name="date_from" type="row"/>
                <field name="employee_id" type="row"/>
                <!--<field name="department_id" type="measure"/>-->
            </pivot>
        </field>
    </record>

    <!--This below action and menu for pivot-->
    <record id="action_hr_payslip_pivot_custom" model="ir.actions.act_window">
        <field name="name">Reporting</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_hr_payslip_pivot_custom"/>
    </record>

    <menuitem id="menu_hr_payslip_pivot_custom"
              name="Reporting"
              parent="hr_payroll_community.menu_hr_payroll_community_root"
              action="action_hr_payslip_pivot_custom"
              sequence="40"/>

</odoo>
