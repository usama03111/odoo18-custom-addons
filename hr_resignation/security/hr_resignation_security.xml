<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Employee: only own resignation -->
    <record id="hr_resignation_rule_user" model="ir.rule">
        <field name="name">Resignation: own and approver</field>
        <field name="model_id" ref="hr_resignation.model_hr_resignation"/>
        <field name="domain_force">['|', '|', '|', '|', '|', ('employee_id.user_id','=',user.id), ('dept_manager_user_id','=',user.id), ('hr_employee_user_id','=',user.id), ('hr_manager_user_id','=',user.id), ('payroll_user_id','=',user.id), ('cfo_user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- HR: see all resignations -->
    <record id="hr_resignation_rule_hr_all" model="ir.rule">
        <field name="name">Resignation: HR all</field>
        <field name="model_id" ref="hr_resignation.model_hr_resignation"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <!-- Employee: only own contracts -->
    <record id="hr_contract_rule_user" model="ir.rule">
        <field name="name">Contract: own</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[('employee_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>