<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ACTION -->
        <record id="action_kb_em_evo_form" model="ir.actions.act_window">
            <field name="name">Employee Evaluations</field>
            <field name="res_model">kb.em.evo.form</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- LIST VIEW -->
        <record id="view_kb_em_evo_form_list" model="ir.ui.view">
            <field name="name">kb.em.evo.form.list</field>
            <field name="model">kb.em.evo.form</field>
            <field name="arch" type="xml">
                <list create="1" delete="0">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="manager_employee_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_kb_em_evo_form_form" model="ir.ui.view">
            <field name="name">kb.em.evo.form.form</field>
            <field name="model">kb.em.evo.form</field>
            <field name="arch" type="xml">
                <form string="Employee Evaluation" create="1" delete="0">

                    <!-- HEADER -->
                    <header>
                        <!-- HR -->
                        <button name="action_send_to_manager"
                                type="object"
                                string="Send to Manager"
                                class="btn-primary"
                                groups="kb_em_evo_form.group_hr_employee_evaluation"
                                modifiers="{'invisible': [('state','!=','draft')]}"/>

                        <!-- MANAGER -->
                        <button name="action_submit_to_hr"
                                type="object"
                                string="Submit to HR"
                                class="btn-primary"
                                groups="kb_em_evo_form.group_manager_employee_evaluation"
                                modifiers="{'invisible': [('state','!=','sent')]}"/>

                        <!-- HR -->
                        <button name="action_done"
                                type="object"
                                string="Mark Done"
                                groups="kb_em_evo_form.group_hr_employee_evaluation"
                                modifiers="{'invisible': [('state','!=','submitted')]}"/>

                        <field name="state"
                               widget="statusbar"
                               statusbar_visible="draft,sent,submitted,done"/>
                    </header>

                    <sheet>

                        <!-- TITLE -->
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <!-- BASIC INFO -->
                        <group>
                            <group>
                                <field name="employee_id"
                                       modifiers="{'readonly':[('state','!=','draft')]}"/>

                                <field name="manager_employee_id" readonly="1"/>
                                <field name="manager_user_id" readonly="1"/>
                            </group>

                            <group>
                                <field name="date" readonly="1"/>
                                <field name="hr_user_id" readonly="1"/>
                            </group>
                        </group>

                        <!-- NOTEBOOK -->
                        <notebook>

                            <!-- MANAGER EVALUATION -->
                            <page string="تقييم المدير المباشر">
                                <field name="evaluation_line_ids"
                                       modifiers="{'readonly':[('state','!=','sent')]}">
                                    <list editable="bottom">
                                        <field name="sequence" string="#"/>
                                        <field name="category" string="المجال"/>
                                        <field name="description" string="الوصف"/>
                                        <field name="rating" widget="radio" string="التقييم"/>
                                    </list>
                                </field>
                            </page>

                            <!-- HR NOTES -->
                            <page string="HR Notes"
                                  groups="kb_em_evo_form.group_hr_employee_evaluation">
                                <group>
                                    <field name="hr_notes"/>
                                </group>
                            </page>

                            <!-- CHATTER -->
                            <page string="Chatter">
                                <field name="message_follower_ids" widget="mail_followers"/>
                                <field name="activity_ids" widget="mail_activity"/>
                                <field name="message_ids" widget="mail_thread"/>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW (Odoo 18 SAFE) -->
        <record id="view_kb_em_evo_form_search" model="ir.ui.view">
            <field name="name">kb.em.evo.form.search</field>
            <field name="model">kb.em.evo.form</field>
            <field name="arch" type="xml">
                <search>
                    <field name="employee_id"/>
                    <field name="manager_employee_id"/>

                    <filter string="Draft"
                            name="draft"
                            domain="[('state','=','draft')]"/>

                    <filter string="Sent"
                            name="sent"
                            domain="[('state','=','sent')]"/>

                    <filter string="Submitted"
                            name="submitted"
                            domain="[('state','=','submitted')]"/>

                    <filter string="Done"
                            name="done"
                            domain="[('state','=','done')]"/>
                </search>
            </field>
        </record>

    </data>
</odoo>
