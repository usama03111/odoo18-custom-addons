<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_eval_btn" model="ir.ui.view">
        <field name="name">hr.employee.form.kb.manager.eval.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_manager_evaluation"
                        string="Send Manager Evaluation"
                        type="object"
                        class="btn-primary"
                        />
            </xpath>
        </field>
    </record>
</odoo>
