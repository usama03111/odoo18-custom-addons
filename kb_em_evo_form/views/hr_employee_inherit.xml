<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_employee_form_inherit_kb_em_evo_form" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.kb.em.evo.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_open_manager_evaluation"
                            type="object"
                            string="Manager Evaluation"
                            class="btn-secondary"
                            groups="kb_em_evo_form.group_hr_employee_evaluation"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
