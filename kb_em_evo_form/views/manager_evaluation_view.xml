<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manager_eval_tree" model="ir.ui.view">
        <field name="name">kb.manager.evaluation.tree</field>
        <field name="model">kb.manager.evaluation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_manager_eval_form" model="ir.ui.view">
        <field name="name">kb.manager.evaluation.form</field>
        <field name="model">kb.manager.evaluation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_to_manager"
                            string="Send to Manager"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="hr.group_hr_user"/>
                    <button name="action_submit_to_hr"
                            string="Submit to HR"
                            type="object"
                            class="btn-success"
                            invisible="state != 'sent'"
                            />
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="manager_id" readonly="1"/>
                        <field name="hr_user_id" readonly="1"/>
                    </group>
                    <group string="Manager Feedback">
                        <field name="evaluation_notes" readonly="state != 'sent'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_manager_evaluation" model="ir.actions.act_window">
        <field name="name">Manager Evaluations</field>
        <field name="res_model">kb.manager.evaluation</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_manager_evaluation_root"
              name="Manager Evaluations"
              parent="hr.menu_hr_root"
              action="action_manager_evaluation"
              groups="hr.group_hr_user"
              sequence="220"/>
</odoo>
