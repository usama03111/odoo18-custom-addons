<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Helper: rating scale 1..5 (selected filled) -->
        <template id="eval_rating_scale">
            <t t-set="v" t-value="value or ''"/>
            <span class="ev-scale">
                <span class="ev-item"><span t-att-class="'ev-dot %s' % ('on' if v=='1' else '')"></span>1
                </span>
                <span class="ev-item"><span t-att-class="'ev-dot %s' % ('on' if v=='2' else '')"></span>2
                </span>
                <span class="ev-item"><span t-att-class="'ev-dot %s' % ('on' if v=='3' else '')"></span>3
                </span>
                <span class="ev-item"><span t-att-class="'ev-dot %s' % ('on' if v=='4' else '')"></span>4
                </span>
                <span class="ev-item"><span t-att-class="'ev-dot %s' % ('on' if v=='5' else '')"></span>5
                </span>
            </span>
        </template>


        <template id="report_template_evaluation_new">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">

                        <!-- KEEP: your header -->
                        <t t-call="kb_employee_evaluation_new.header_id"/>

                        <div class="page">

                            <style>
                                .ev-wrap{direction:rtl; font-size:12px;}
                                .ev-title{font-weight:700; margin:0 0 8px 0;}
                                .ev-table{width:100%; border-collapse:collapse; margin:10px 0;}
                                .ev-table th,.ev-table td{border:1px solid #333; padding:6px; vertical-align:middle;}
                                .ev-head{background:#e9e9e9; font-weight:700; text-align:center;}
                                .ev-num{width:40px; text-align:center;}
                                .ev-field{width:120px; text-align:center; font-weight:700;}
                                .ev-desc{text-align:right;}
                                .ev-rate{width:240px; text-align:center; direction:ltr; white-space:nowrap;}

                                .ev-scale{display:inline-block;}
                                .ev-item{display:inline-block; margin:0 4px; font-size:11px;}
                                .ev-dot{
                                display:inline-block;
                                width:10px; height:10px;
                                border:1px solid #444;
                                border-radius:50%;
                                vertical-align:middle;
                                margin-right:2px;
                                }
                                .ev-dot.on{background:#6b6b6b;}
                            </style>

                            <div class="ev-wrap">
                               


                                <div class="ev-title">
                                    8- تقييم الأداء: تقييم فترة التجربة - تقييم قبل نهاية العقد - التقييم السنوي
                                </div>

                                <!-- ================= Manager Evaluation ================= -->
                                <table class="ev-table">
                                    <tr>
                                        <th class="ev-head" colspan="4">تقييم المدير المباشر للموظف</th>
                                    </tr>
                                    <tr>
                                        <th class="ev-head ev-rate">التقييم (1 - 5)</th>
                                        <th class="ev-head">الوصف</th>
                                        <th class="ev-head ev-field">المجال</th>
                                        <th class="ev-head ev-num">#</th>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_leadership"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف</td>
                                        <td class="ev-field">القيادة</td>
                                        <td class="ev-num">1</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_communication"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">وضوح وفعالية التواصل مع الآخرين</td>
                                        <td class="ev-field">التواصل</td>
                                        <td class="ev-num">2</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_teamwork"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td class="ev-field">العمل الجماعي</td>
                                        <td class="ev-num">3</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_problem_solving"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td class="ev-field">حل المشكلات</td>
                                        <td class="ev-num">4</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_commitment"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td class="ev-field">الالتزام</td>
                                        <td class="ev-num">5</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_teamwork_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td class="ev-field">العمل الجماعي</td>
                                        <td class="ev-num">6</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_problem_solving_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td class="ev-field">حل المشكلات</td>
                                        <td class="ev-num">7</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_commitment_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td class="ev-field">الالتزام</td>
                                        <td class="ev-num">8</td>
                                    </tr>
                                </table>

                                <!-- ================= Self Evaluation ================= -->
                                <table class="ev-table">
                                    <tr>
                                        <th class="ev-head" colspan="4">(التقييم الذاتي (تقييم الموظف لنفسه</th>
                                    </tr>
                                    <tr>
                                        <th class="ev-head ev-rate">التقييم (1 - 5)</th>
                                        <th class="ev-head">الوصف</th>
                                        <th class="ev-head ev-field">المجال</th>
                                        <th class="ev-head ev-num">#</th>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_leadership"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف</td>
                                        <td class="ev-field">القيادة</td>
                                        <td class="ev-num">1</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_communication"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">وضوح وفعالية التواصل مع الآخرين</td>
                                        <td class="ev-field">التواصل</td>
                                        <td class="ev-num">2</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_teamwork"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td class="ev-field">العمل الجماعي</td>
                                        <td class="ev-num">3</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_problem_solving"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td class="ev-field">حل المشكلات</td>
                                        <td class="ev-num">4</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_commitment"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td class="ev-field">الالتزام</td>
                                        <td class="ev-num">5</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_teamwork_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td class="ev-field">العمل الجماعي</td>
                                        <td class="ev-num">6</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_problem_solving_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td class="ev-field">حل المشكلات</td>
                                        <td class="ev-num">7</td>
                                    </tr>

                                    <tr>
                                        <td class="ev-rate">
                                            <t t-call="kb_employee_evaluation_new.eval_rating_scale">
                                                <t t-set="value" t-value="o.self_commitment_2"/>
                                            </t>
                                        </td>
                                        <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td class="ev-field">الالتزام</td>
                                        <td class="ev-num">8</td>
                                    </tr>
                                </table>

                                <div style="margin-top:8px;">
                                    <b>نتيجة التقييم:</b>
                                    من 40-35 ممتاز — من 34-28 جيد جداً — من 27-21 جيد — من 18-13 مقبول — من 12-8 ضعيف
                                </div>

                                <div style="margin-top:10px;">
                                    <div>
                                        <b>مجموع نقاط التقييم</b>
                                    </div>
                                    <div>- تقييم المدير للموظف 80%:
                                        <span t-esc="o.mgr_total"/>
                                    </div>
                                    <div>- تقييم الموظف لنفسه 20%:
                                        <span t-esc="o.self_total"/>
                                    </div>
                                    <div>
                                        <b>النتيجة النهائية:</b>
                                        <span t-esc="o.final_total"/>
                                        —
                                        <span t-esc="o.final_result"/>
                                    </div>
                                </div>

                            </div>

                        </div>

                        <!-- KEEP: your footer -->
                        <t t-call="kb_employee_evaluation_new.footer_id"/>

                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
