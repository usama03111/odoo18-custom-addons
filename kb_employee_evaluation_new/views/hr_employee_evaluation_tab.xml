<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record id="view_hr_employee_form_inherit_eval_tab" model="ir.ui.view">
      <field name="name">hr.employee.form.inherit.evaluation.tab</field>
      <field name="model">hr.employee</field>
      <field name="inherit_id" ref="hr.view_employee_form"/>
      <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
          <page string="Evaluation" name="evaluation_tab">

            <style>
              .ev-wrap{direction:rtl; font-size:13px;}
              .ev-title{font-weight:700; margin-bottom:8px;}
              .ev-table{width:100%; border-collapse:collapse; margin:10px 0;}
              .ev-table th,.ev-table td{border:1px solid #333; padding:6px; vertical-align:middle;}
              .ev-head{background:#e9e9e9; font-weight:700; text-align:center;}
              .ev-num{width:40px; text-align:center;}
              .ev-field{width:160px; text-align:center; font-weight:700;}
              .ev-desc{text-align:right;}
              .ev-rate{width:220px; text-align:center; direction:ltr;}
              /* radio horizontal */
              .o_field_radio{white-space:nowrap;}
            </style>

            <div class="ev-wrap">
              <div class="ev-title">
                8- تقييم الأداء: تقييم فترة التجربة - تقييم قبل نهاية العقد - التقييم السنوي
              </div>

              <!-- ===== Manager Evaluation ===== -->
              <table class="ev-table">
                <tr>
                  <th class="ev-head" colspan="4">تقييم المدير المباشر للموظف</th>
                </tr>
                <tr>
                  <th class="ev-head ev-rate">التقييم (1 - 5)</th>
                  <th class="ev-head">الوصف</th>
                  <th class="ev-head ev-field">المجال</th>
                  <th class="ev-head ev-num">#</th>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_leadership" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف</td>
                  <td class="ev-field">القيادة</td>
                  <td class="ev-num">1</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_communication" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">وضوح وفعالية التواصل مع الآخرين</td>
                  <td class="ev-field">التواصل</td>
                  <td class="ev-num">2</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_teamwork" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                  <td class="ev-field">العمل الجماعي</td>
                  <td class="ev-num">3</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_problem_solving" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                  <td class="ev-field">حل المشكلات</td>
                  <td class="ev-num">4</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_commitment" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                  <td class="ev-field">الالتزام</td>
                  <td class="ev-num">5</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_teamwork_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                  <td class="ev-field">العمل الجماعي</td>
                  <td class="ev-num">6</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_problem_solving_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                  <td class="ev-field">حل المشكلات</td>
                  <td class="ev-num">7</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="mgr_commitment_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                  <td class="ev-field">الالتزام</td>
                  <td class="ev-num">8</td>
                </tr>
              </table>

              <!-- ===== Self Evaluation ===== -->
              <table class="ev-table">
                <tr>
                  <th class="ev-head" colspan="4">(التقييم الذاتي (تقييم الموظف لنفسه</th>
                </tr>
                <tr>
                  <th class="ev-head ev-rate">التقييم (1 - 5)</th>
                  <th class="ev-head">الوصف</th>
                  <th class="ev-head ev-field">المجال</th>
                  <th class="ev-head ev-num">#</th>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_leadership" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف</td>
                  <td class="ev-field">القيادة</td>
                  <td class="ev-num">1</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_communication" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">وضوح وفعالية التواصل مع الآخرين</td>
                  <td class="ev-field">التواصل</td>
                  <td class="ev-num">2</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_teamwork" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                  <td class="ev-field">العمل الجماعي</td>
                  <td class="ev-num">3</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_problem_solving" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                  <td class="ev-field">حل المشكلات</td>
                  <td class="ev-num">4</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_commitment" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                  <td class="ev-field">الالتزام</td>
                  <td class="ev-num">5</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_teamwork_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                  <td class="ev-field">العمل الجماعي</td>
                  <td class="ev-num">6</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_problem_solving_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                  <td class="ev-field">حل المشكلات</td>
                  <td class="ev-num">7</td>
                </tr>

                <tr>
                  <td class="ev-rate"><field name="self_commitment_2" widget="radio" options="{'horizontal': true}"/></td>
                  <td class="ev-desc">الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                  <td class="ev-field">الالتزام</td>
                  <td class="ev-num">8</td>
                </tr>
              </table>

              <!-- Legend + totals -->
              <div style="margin-top:8px;">
                <b>نتيجة التقييم:</b>
                من 40-35 ممتاز — من 34-28 جيد جداً — من 27-21 جيد — من 18-13 مقبول — من 12-8 ضعيف
              </div>

              <div style="margin-top:10px;">
                <div><b>مجموع نقاط التقييم</b></div>
                <div>- تقييم المدير للموظف 80%: <field name="mgr_total" readonly="1"/></div>
                <div>- تقييم الموظف لنفسه 20%: <field name="self_total" readonly="1"/></div>
                <div><b>النتيجة النهائية:</b> <field name="final_total" readonly="1"/> — <field name="final_result" readonly="1"/></div>
              </div>
            </div>

          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
