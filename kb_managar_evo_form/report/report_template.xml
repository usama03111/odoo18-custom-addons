<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Rating dots -->
        <template id="eval_rating_scale">
            <t t-set="v" t-value="value or ''"/>
            <span style="direction:ltr; white-space:nowrap;">
                <t t-foreach="['1','2','3','4','5']" t-as="i">
                    <span style="margin:0 3px;">
                        <span t-att-style="
                            'display:inline-block;width:10px;height:10px;border:1px solid #333;border-radius:50%;'
                            + ('background:#333;' if v==i else '')"/>
                        <span t-esc="i"/>
                    </span>
                </t>
            </span>
        </template>

        <!-- MAIN REPORT -->
        <template id="report_template_managar_evo_form">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">

                        <t t-call="kb_managar_evo_form.header_id"/>

                        <div class="page" style="direction:rtl; font-size:12px;">

                            <!-- EMPLOYEE INFO -->
                            <div style="margin-bottom:8px;">
                                <b>الموظف:</b>
                                <span t-esc="o.name"/>
                                <span style="margin:0 12px;">|</span>
<!--                                <b>السنة:</b>-->
<!--                                <span t-esc="o.year"/>-->
                            </div>

                            <!-- TABLE -->
                            <table style="width:100%; border-collapse:collapse;" border="1">
                                <thead>
                                    <tr style="background:#f0f0f0;">
                                        <th colspan="4" style="text-align:center;">
                                            تقييم المدير المباشر للموظف
                                        </th>
                                    </tr>
                                    <tr style="background:#f0f0f0;">
                                        <th style="width:5%;">#</th>
                                        <th style="width:15%;">المجال</th>
                                        <th>الوصف</th>
                                        <th style="width:25%; direction:ltr;">التقييم (1 - 5)</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td>القيادة</td>
                                        <td>قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_leadership"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>2</td>
                                        <td>التواصل</td>
                                        <td>وضوح وفعالية التواصل مع الآخرين</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_communication"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>3</td>
                                        <td>العمل الجماعي</td>
                                        <td>المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_teamwork"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>4</td>
                                        <td>حل المشكلات</td>
                                        <td>القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_problem_solving"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>5</td>
                                        <td>الالتزام</td>
                                        <td>الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_commitment"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>6</td>
                                        <td>العمل الجماعي</td>
                                        <td>المساهمة الإيجابية في الفريق ودعم الزملاء</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_teamwork_2"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>7</td>
                                        <td>حل المشكلات</td>
                                        <td>القدرة على تحليل المشكلات واتخاذ قرارات مناسبة</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_problem_solving_2"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>8</td>
                                        <td>الالتزام</td>
                                        <td>الالتزام بالسياسات والقيم وأخلاقيات العمل</td>
                                        <td>
                                            <t t-call="kb_managar_evo_form.eval_rating_scale">
                                                <t t-set="value" t-value="o.mgr_commitment_2"/>
                                            </t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- NOTE -->
                            <div style="margin-top:10px;">
                                <b>ملاحظة:</b>
                                <br/>
                                هذا التقييم خاص بالموظف مجرد ولا يحتاج ذكر اسمه فقط ذكر القسم – الفرع.
                                <br/>
                                يعمل التقييم لمدير الموارد البشرية + مشرف الموارد البشرية.
                                <br/>
                                إضافة الورق الرسمي للشركة.
                            </div>

                            <!-- TOTAL -->
<!--                            <div style="margin-top:10px;">-->
<!--                                <b>Final Total:</b>-->
<!--                                <span t-esc="o.final_total"/>-->
<!--                                <span style="margin:0 10px;">|</span>-->
<!--                                <b>Result:</b>-->
<!--                                <span t-esc="dict(o._fields['final_result'].selection).get(o.final_result)"/>-->
<!--                            </div>-->

                        </div>

                        <t t-call="kb_managar_evo_form.footer_id"/>

                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
