<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_eval_tabs" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.manager.evaluation</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Manager Evaluation">

                    <field name="manager_evaluation_ids"
                           context="{'default_employee_id': id}"
                           nolabel="1">

                        <!-- LIST -->
                        <list>
                            <field name="year"/>
                            <field name="date"/>
                            <field name="final_total"/>
                            <field name="final_result"/>
                        </list>

                        <!-- FORM -->
                        <form>
                            <sheet>

                                <group>
                                    <field name="employee_id" readonly="1"/>
                                    <field name="year"/>
                                    <field name="date"/>
                                </group>

                                <separator string="تقييم المدير المباشر للموظف"/>

                                <!-- ================= REAL TABLE ================= -->
                                <table class="kb-eval-table">

                                    <!-- TABLE TITLE -->
                                    <thead>
                                        <tr>
                                            <th colspan="4">
                                                تقييم المدير المباشر للموظف
                                            </th>
                                        </tr>
                                        <tr>
                                            <th class="kb-eval-num">#</th>
                                            <th class="kb-eval-field">المجال</th>
                                            <th>الوصف</th>
                                            <th class="kb-eval-rate">(1 - 5) التقييم</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <!-- 1 -->
                                        <tr>
                                            <td class="kb-eval-num">1</td>
                                            <td class="kb-eval-field">القيادة</td>
                                            <td class="kb-eval-desc">
                                                قدرة الموظف على توجيه وتحفيز الفريق لتحقيق الأهداف
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_leadership" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 2 -->
                                        <tr>
                                            <td class="kb-eval-num">2</td>
                                            <td class="kb-eval-field">التواصل</td>
                                            <td class="kb-eval-desc">
                                                وضوح وفعالية التواصل مع الآخرين
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_communication" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 3 -->
                                        <tr>
                                            <td class="kb-eval-num">3</td>
                                            <td class="kb-eval-field">العمل الجماعي</td>
                                            <td class="kb-eval-desc">
                                                المساهمة الإيجابية في الفريق ودعم الزملاء
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_teamwork" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 4 -->
                                        <tr>
                                            <td class="kb-eval-num">4</td>
                                            <td class="kb-eval-field">حل المشكلات</td>
                                            <td class="kb-eval-desc">
                                                القدرة على تحليل المشكلات واتخاذ قرارات مناسبة
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_problem_solving" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 5 -->
                                        <tr>
                                            <td class="kb-eval-num">5</td>
                                            <td class="kb-eval-field">الالتزام</td>
                                            <td class="kb-eval-desc">
                                                الالتزام بالسياسات والقيم وأخلاقيات العمل
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_commitment" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 6 -->
                                        <tr>
                                            <td class="kb-eval-num">6</td>
                                            <td class="kb-eval-field">العمل الجماعي</td>
                                            <td class="kb-eval-desc">
                                                المساهمة الإيجابية في الفريق ودعم الزملاء
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_teamwork_2" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 7 -->
                                        <tr>
                                            <td class="kb-eval-num">7</td>
                                            <td class="kb-eval-field">حل المشكلات</td>
                                            <td class="kb-eval-desc">
                                                القدرة على تحليل المشكلات واتخاذ قرارات مناسبة
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_problem_solving_2" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>

                                        <!-- 8 -->
                                        <tr>
                                            <td class="kb-eval-num">8</td>
                                            <td class="kb-eval-field">الالتزام</td>
                                            <td class="kb-eval-desc">
                                                الالتزام بالسياسات والقيم وأخلاقيات العمل
                                            </td>
                                            <td class="kb-eval-rate">
                                                <field name="mgr_commitment_2" widget="radio"
                                                       options="{'horizontal': true}"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>

                                <!-- NOTE -->
                                <div style="margin-top:12px; font-size:12px; direction:rtl;">
                                    <b>ملاحظة:</b>
                                    <br/>
                                    هذا التقييم خاص بالموظف مجرد ولا يحتاج ذكر اسمه فقط ذكر القسم – الفرع (أحد الفروع أو
                                    الدائرة).
                                    <br/>
                                    يعمل التقييم لمدير الموارد البشرية + مشرف الموارد البشرية.
                                    <br/>
                                    إضافة الورق الرسمي للشركة.
                                </div>

                                <separator string="النتيجة النهائية"/>

                                <group>
                                    <field name="mgr_total" readonly="1"/>
                                    <field name="final_total" readonly="1"/>
                                    <field name="final_result" readonly="1"/>
                                </group>

                            </sheet>
                        </form>

                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
