<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_inherit_material_request" model="ir.ui.view">
        <field name="name">project.project.form.inherit.material.request</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Material Requests" name="material_requests">
                    <field name="material_request_ids" >
                        <list string="Material Requests" create="0">
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="date"/>
                            <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-muted="state == 'cancelled'"/>
                            <field name="purchase_count" optional="show"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="material_cost" widget="monetary"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
