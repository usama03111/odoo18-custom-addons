<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit the common report options form to add partner selection -->
    <record id="account_report_partner_ledger_view_m2m" model="ir.ui.view">
        <field name="name">account.report.partner.ledger.view.form.add.partners</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="inherit_id" ref="base_accounting_kit.account_report_partner_ledger_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='result_selection']" position="after">
                <field name="partner_ids" widget="many2many_tags" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>


