<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Sales tab visibility -->
    <record id="view_partner_form_inherit_sales_privacy_base" model="ir.ui.view">
        <field name="name">res.partner.form.sales.privacy.base</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="before">
                <field name="hide_sales_tab" invisible="1"/>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">hide_sales_tab == True</attribute>
            </xpath>
        </field>
    </record>

    <!-- Accounting tab visibility -->
    <record id="view_partner_form_inherit_sales_privacy_account" model="ir.ui.view">
        <field name="name">res.partner.form.sales.privacy.account</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="before">
                <field name="hide_account_tab" invisible="1"/>
            </xpath>

            <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="invisible">hide_account_tab == True</attribute>
            </xpath>
        </field>
    </record>
</odoo>
