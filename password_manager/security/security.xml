<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="password_entry_rule_personal_authorized" model="ir.rule">
            <field name="name">Password Entry: Personal or Authorized</field>
            <field name="model_id" ref="model_password_entry"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('user_ids', 'in', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
