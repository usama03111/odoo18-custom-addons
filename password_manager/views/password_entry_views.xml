<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_password_tag_form" model="ir.ui.view">
        <field name="name">password.tag.form</field>
        <field name="model">password.tag</field>
        <field name="arch" type="xml">
            <form string="Password Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_password_entry_form" model="ir.ui.view">
        <field name="name">password.entry.form</field>
        <field name="model">password.entry</field>
        <field name="arch" type="xml">
            <form string="Password Entry">
                <header>
                    <button name="action_reveal" string="Reveal Password" type="object" class="oe_highlight" icon="fa-eye"/>
                    <button name="action_copy_password" string="Copy Password" type="object" class="btn-secondary" icon="fa-clipboard"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Google Account"/></h1>
                    </div>
                        <group>
                            <field name="url" widget="url"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                            <field name="tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page string="Authorized Users">
                            <field name="user_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_password_entry_list" model="ir.ui.view">
        <field name="name">password.entry.list</field>
        <field name="model">password.entry</field>
        <field name="arch" type="xml">
            <list string="Password Entries">
                <field name="name"/>
                <field name="url"/>
                <field name="username"/>
                <field name="tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </list>
        </field>
    </record>

    <record id="action_password_entry" model="ir.actions.act_window">
        <field name="name">Passwords</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">password.entry</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_password_manager_root" name="Password Manager" web_icon="password_manager,static/description/icon.png"/>
    <menuitem id="menu_password_entry" name="Passwords" parent="menu_password_manager_root" action="action_password_entry"/>
</odoo>
