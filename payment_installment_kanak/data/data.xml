        <record id="ir_cron_multiple_invoice" model="ir.cron">
            <field name="name">Installment Multiple Invoice</field>
            <field name="model_id" ref="sale.model_sale_order" />
            <field name="state">code</field>
            <field name="code">model.check_and_create_invoice()</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
<!--            <field name="numbercall">-1</field>-->
        </record>

        <record id="ir_cron_multiple_installment_overdue_reminder" model="ir.cron">
            <field name="name">Multiple Installment Overdue Reminder</field>
            <field name="model_id" ref="sale.model_sale_order" />
            <field name="state">code</field>
            <field name="code">model.installment_overdue_reminder()</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

        <record id="mail_template_installment_reminder" model="mail.template">
            <field name="name">Installment Reminder</field>
            <field name="model_id" ref="payment_installment_kanak.model_invoice_installment_line" />
            <field name="subject">Reminder Installment</field>
            <field name="email_from">{{ ctx.get('email_from') }}</field>
            <field name="email_to">{{ object.invoice_id.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;"> Dear
                        <t t-if="object.invoice_id.partner_id.parent_id">
                            <t t-out="object.invoice_id.partner_id.name or ''">Brandon Freeman</t> (<t t-out="object.invoice_id.partner_id.parent_id.name or ''">Azure Interior</t>),
                        </t>
                        <t t-else="">
                            <t t-out="object.invoice_id.partner_id.name or ''">Brandon Freeman</t>,
                        </t>
                        <br /><br />
                        As per our discussion, I am sharing the 
                        <strong><t t-out="object.description"/></strong> (with reference: <strong><t t-out="object.invoice_id.invoice_origin or ''">SUB003</t></strong>)
                        amount of <span style="font-weight:bold;" t-out="format_amount(object.amount, object.invoice_id.currency_id) or ''">$ 143,750.00</span>.
                        Please remit payment at your earliest convenience and complete the transaction to avoid any issues.
                        <t t-if="object.invoice_id.payment_reference">
                            <br /><br />
                            For more details and communication of your payment, check the info: <span style="font-weight:bold;" t-out="object.invoice_id.payment_reference or ''">INV/2021/05/0005</span>.
                        </t>
                        <br /><br />
                        You can reach us in case of any queries.
                        <t t-if="not is_html_empty(object.invoice_id.invoice_user_id.signature)">
                            <br /><br />
                            <t t-out="object.invoice_id.invoice_user_id.signature or ''">--<br />Mitchell Admin</t>
                        </t>
                    </p>
                </div>
            </field>
            <field name="lang">{{ object.invoice_id.partner_id.lang }}</field>
            <field name="auto_delete" eval="True" />
        </record>

        <record id="mail_template_multiple_installment_overdue" model="mail.template">
            <field name="name">Multiple Installment Overdue Reminder</field>
            <field name="model_id" ref="account.model_account_move" />
            <field name="subject">Installment Payment Reminder for {{object.name}}</field>
            <field name="email_from">{{ ctx.get('email_from') }}</field>
            <field name="email_to">{{object.partner_id.email or ''}}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.partner_id.name or ''">Customer</t>,<br/><br/>
                        This is a friendly reminder that the installment invoice
                        <strong><t t-out="object.name or ''">INV/0001</t></strong>
                        with due date
                        <strong><t t-out="format_date(object.invoice_date_due) if object.invoice_date_due else ''">01/01/2025</t></strong>
                        is still unpaid.<br/><br/>
                        The outstanding amount is
                        <span style="font-weight:bold;" t-out="format_amount(object.amount_residual, object.currency_id) or ''">$ 0.00</span>.<br/><br/>
                        Please arrange the payment at your earliest convenience.<br/><br/>
                        Best regards,<br/>
                        <t t-out="object.invoice_user_id.name or user.name or ''">Your Company</t>
                    </p>
                </div>
            </field>
            <field name="lang">{{object.partner_id.lang}}</field>
            <field name="auto_delete" eval="True" />
        </record>

        <record id="mail_activity_data_invoice_sent" model="mail.activity.type">
            <field name="name">Invoice Sent</field>
            <field name="icon">fa-file-invoice</field>
            <field name="sequence">5</field>
            <field name="active">True</field>
            <field name="res_model">sale.order</field>
        </record>
    </data>
</odoo>