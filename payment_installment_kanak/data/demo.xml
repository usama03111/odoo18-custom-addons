<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="account_payment_term_4months" model="account.payment.term">
        
        <field name="name">4 Months (Quater)</field>
        <field name="note">Installment Plans: 4 Months</field>
        <field name="is_plan">True</field>
        <field name="line_ids" eval="[
        	Command.clear(), 
        	Command.create({'description': 'Advance Payment', 'value': 'percent', 'value_amount': 10}), 
        	Command.create({'description': 'Installment', 'period': 'quater', 'value': 'balance', 'months': 4 })]"/>

            <!-- 'start_date': 2023-02-03 00:00:00 -->
    </record>

