<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate='1'>
        <template id="report_invoice_installments_document">
            <t t-call="web.basic_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)" />
                <div>
                    <!-- <div style="font-size:16px" class="header">
                        <div style="margin-bottom:-20px">
                            <div style="height:100px; width:100px; margin-bottom:2px">
                                <t t-if="o.user_id.company_id.logo">
                                    <span t-field="o.user_id.company_id.logo" t-options='{"widget": "image"}' />
                                </t>
                            </div>
                        </div>
                    </div> -->
                    <div class="page">  
                        <div id="customer-info" class="my-4">
                            <div style="font-size: 20px"><strong><t t-esc="o.partner_id.name"/></strong></div>
                            <div>Contact: <t t-esc="o.partner_id.phone"/></div>
                        </div>

                        <div id="basic-details" class="my-4">
                            <div style="font-size: 20px"><strong>Payment Schedule</strong></div>
                            <t t-set="names" t-value="o.get_product_names()" />
                            <div class="mb-1" style="font-size: 16px">
                                <t t-if="len(names) == 1">
                                    <span ><strong>Product:</strong></span>
                                </t>
                                <t t-else="">
                                    <span >Products:</span>
                                </t>
                                <t t-foreach="names" t-as="prod">
                                    <span t-esc="prod" />,
                                </t>
                                <div>Date: <span t-esc="o.invoice_date"/></div>
                            </div>
                        </div>
                        <t t-set="data" t-value="o.get_payment_schedule_data()" />
                        
                        <div class="row" style="font-size: 14px">
                            <div class="col-3">
                                <div class="row my-1">
                                    <div class="col-6" style="font-size: 18px">
                                        Plan Tenure
                                    </div>
                                    <div class="col-6" style="font-size: 16px">
                                        <t t-esc="data['tenure_plan']" />
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Installments
                                    </div>
                                    <div class="col-6">
                                        <t t-esc="data['total_installment']" />
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Total Price
                                    </div>
                                    <div class="col-6">
                                        <t t-esc="data['total_price']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Discount
                                    </div>
                                    <div class="col-6">
                                        <t t-esc="data['discount']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6" style="font-size: 16px">
                                        Net Price
                                    </div>
                                    <div class="col-6" style="font-size: 16px">
                                        <t t-esc="round(data['total_price'] - data['discount'],2)" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-5"></div>
                            <div class="col-4">
                                <div class="row my-4">
                                    <div class="col-6" style="font-size: 18px">
                                        Status
                                    </div>
                                    <div t-if="data['status']" class="col-6" style="font-size: 16px; color: green;">
                                        Active
                                    </div>
                                    <div t-else="" class="col-6" style="font-size: 16px; color: red;">
                                        Inactive
                                    </div>
                                </div>
                                <div class="row my-1">
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Amount Paid to Date
                                    </div>
                                    <div class="col-6" style="color: green;">
                                        <t t-esc="data['amount_paid_to_date']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Balance
                                    </div>
                                    <div class="col-6">
                                        <t t-esc="data['balance']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-6">
                                        Overdue Amount
                                    </div>
                                    <div class="col-6" style="color: red">
                                        <t t-esc="data['overdue_amount']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <br />
                        <div>
                            <table class="table table-borderless">
                                <thead style="border-bottom:1px solid">
                                    <th  style="color: blue">S.No.</th>
                                    <th >Description</th>
                                    <th >Amount</th>
                                    <th >Due Date</th>
                                    <th >Status</th>
                                    <th>Amount Paid</th>
                                    <th >Action</th>
                                    <th>Payment Date</th>
                                    <th>Medium</th>
                                </thead>
                                <tbody class="text-center">
                                    <t t-set="sno" t-value="1" />
                                    <t t-foreach="data['values']" t-as="rec">
                                        <tr>
                                            <td >
                                                <t t-esc="sno" />
                                            </td>
                                            <t t-if="rec['description'][2:] == 'installment'">
                                                <td >
                                                    <t t-esc="rec['description'][2:].capitalize() + ' ' + rec['description'][0]" />
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td ><strong>
                                                        <t t-esc="rec['description']" /></strong></td>
                                            </t>
                                            <td >
                                                <t t-esc="round(rec['amount'],2)" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                            <td >
                                                <t t-esc="rec['due_date']" />
                                            </td>
                                            
                                            <td >
                                                <t t-if="rec['status'] == 'due'">
                                                    <div style="color: yellow">Due</div>
                                                </t>
                                                <t t-elif="rec['status'] == 'overdue'">
                                                    <div style="color: red">Overdue</div>
                                                </t>
                                                <t t-else="">
                                                    <div style="color: green">
                                                        <t t-if="rec['status'] == 'paid'">
                                                            Paid
                                                        </t>
                                                        <t t-else="">
                                                            Partial
                                                        </t>
                                                    </div>
                                                </t>
                                            </td>

                                            <t t-if="rec['amount_paid'] > 0">
                                                <td>
                                                    <t t-esc="rec['amount_paid']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td></td>
                                            </t>
                                            <t t-if="rec['status'] != 'paid'">
                                                <td style="color: blue">Pay</td>
                                            </t>
                                            <t t-else="">
                                                <td ></td>
                                            </t>
                                            <td><t t-esc="rec['medium']"/></td>
                                            <td><t t-esc="rec['register_date']"/></td>
                                        </tr>
                                        <t t-set="sno" t-value="sno + 1" />
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="footer">
                        <div class="row">
                            <div class="col-12 pull-center" style="margin-top:30px; text-align:center; color:grey">
                                <span>Page</span>
                                <span class="page" /> of <span class="topage" />
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="report_accountmove_installments_new">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="payment_installment_kanak.report_invoice_installments_document" t-lang="o.partner_id.lang" />
                </t>
            </t>
        </template>
        <record id="action_invoice_report_installments" model="ir.actions.report">
            <field name="name">Invoice Installments</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">payment_installment_kanak.report_accountmove_installments_new</field>
            <field name="report_file">payment_installment_kanak.report_accountmove_installments_new</field>
            <field name="paperformat_id" ref="payment_installment_kanak.installment_paperformat" />
           <field name="print_report_name">'Invoice Installments - %s' % (object.name)</field>
            <field name="binding_model_id" ref="account.model_account_move" />
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>