<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="view_move_form_installment">
        <field name="name">account.move.form.installment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="enable_installment" invisible="1"/>
                <field name="single_invoice_installment" invisible="1"/>
                <field name="multiple_invoice_installment" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='invoice_payment_term_id']" position="after">
                <field name="check_invoice_type" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_register_payment']" position="attributes">
                <attribute name="invisible">(single_invoice_installment == True) or (state == 'draft') or (payment_state == 'paid')</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Installments" name="installments" invisible="(enable_installment == False) or (multiple_invoice_installment == True)">
                    <button name="%(action_sub_part_payment_confirm)d" string="Part Payment" type="action" context="{'default_move_id': id}" class="oe_highlight" style="border-color: #2196F3; margin-left: 10px !important;" invisible="(payment_state == 'paid') or (state != 'posted')"/>
                    <group></group>
                    <br />
                    <group>
                        <group>
                            <field name="tenure" readonly="1" />
                        </group>
                        <group>
                            <field name="installment_amt" readonly="1" />
                        </group>
                    </group>
                    <group col="4">
                        <field name="tenure_amt" invisible='True' />
                        <field name="down_payment_amt" invisible='True' />
                        <field name="payable_amt" invisible='True' />
                        <field name="first_installment_date" invisible='True' />
                    </group>
                    <br />
                    <field name="installment_ids">
                        <list editable="bottom" class="installment_table" string="Installments" create="0" edit="0" delete="0">
                            <field name="index" class="installment_index-left-align"/>
                            <field name="description" />
                            <field name="amount" sum="Total Amount" />
                            <field name="payment_date" />
                            <field name="state" readonly="1" decoration-success="state == 'paid'"/>
                            <button name="make_payment" type="object" title="Make Payment for installment" string="Pay" invisible="(state == 'paid') or (parent.payment_state ==  'paid')" />
                        </list>
                    </field>
                    <div class="installment_invoice_right_align">
                        <h3 style="margin-right: 50px; margin-bottom: 10px">Summary</h3>
                        <label for="paid_amount_summary" />
                        <field name="paid_amount_summary" class="installment_label"/><br/>
                        <label for="balance_amount_summary" />
                        <field name="balance_amount_summary" class="installment_label"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
    <record model="ir.ui.view" id="view_order_form_installment">
        <field name="name">sale.order.form.installment</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="enable_installment" invisible="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Installments" name="installments" invisible="(enable_installment == False)">

                    <group>
                        <group>
                            <field name="installment_plans_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
<!---->
                            <field name="tenure_amt" invisible="installment_plans_id == False"/>
                            <field name="payable_amt" invisible="installment_plans_id == False" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="installment_reminder_days"/>
                        </group>
                    </group>
                    <br />
                    <group>
                        <field name="down_payment_amt_ids" invisible="installment_plans_id == False" readonly="state != 'draft'">
                            <list editable="bottom" string="Down Payments">
                                <field name="description" />
                                <field name="due_date" />
                                <field name="amount" />
                            </list>
                        </field>
                    </group>
                    <group>
                        <group>
                            <field name="tenure" invisible="installment_plans_id == False" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="tenure_plan" invisible="installment_plans_id == False" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="installment_amt" invisible="installment_plans_id == False" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="first_installment_date" invisible="installment_plans_id == False" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <br/>
                    <field name="installment_ids" readonly="invoice_status ==  'invoiced'">
                        <list editable="bottom" string="Installments" create="0">
                            <field name="index" />
                            <field name="payment_date" />
                            <field name="amount" sum="Total Amount" />
                            <field name="description" />
                            <field name="state" readonly="1" />
                        </list>
                    </field>
                </page>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="mul_inv_first_created" invisible="1"/>
            </xpath>
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="invisible">(mul_inv_first_created == False) or (invoice_status == 'invoiced')</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice_percentage']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
        </field>
    </record>
</odoo>