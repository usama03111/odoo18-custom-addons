<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit default sale order report to append installment table after totals -->
    <template id="payment_installment_kanak_sale_report_installments"
              inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@name='total']/parent::div" position="after">
            <t t-if="doc.installment_ids">
                <t t-set="schedule" t-value="doc.get_payment_schedule_data()"/>
                <t t-set="vals" t-value="schedule.get('values', [])"/>

                <div class="mt32 mb32">
                    <h3 class="text-uppercase" style="font-weight: 600;">Installment Plan</h3>

                    <!-- Counter for S.No -->
                    <t t-set="counter" t-value="0"/>

                    <!-- Installment Table -->
                    <table class="table table-sm o_main_table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid #000;">
                                <th style="text-align:left;">S.No.</th>
                                <th style="text-align:left;">Description</th>
                                <th style="text-align:right;">Amount</th>
                                <th style="text-align:center;">Due Date</th>
                                <th style="text-align:center;">Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="vals" t-as="rec">
                                <tr>
                                    <!-- Serial No -->
                                    <td>
                                        <t t-set="counter" t-value="counter + 1"/>
                                        <t t-esc="counter"/>
                                    </td>

                                    <!-- Description -->
                                    <td>
                                        <t t-esc="rec.get('description') or ''"/>
                                    </td>

                                    <!-- Amount (with currency formatting) -->
                                    <td style="text-align:right;">
                                        <t t-esc="doc.currency_id.symbol"/>
                                        <t t-esc="'{:,.2f}'.format(rec.get('amount', 0.0))"/>
                                    </td>

                                    <!-- Due Date -->
                                    <td style="text-align:center;">
                                        <t t-esc="rec.get('due_date') or ''"/>
                                    </td>

                                    <!-- Status -->
                                    <td style="text-align:center;">
                                        <t t-esc="rec.get('status') or ''"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
            <t t-if="not doc.installment_ids and doc.installment_plans_id">
                <div class="mt32 mb32">
                    <h3 class="text-uppercase" style="font-weight: 600;">Installment Plan Details</h3>
                    
                    <table class="table table-sm o_main_table table-bordered" style="width: 100%; border-collapse: collapse; border: 1px solid black;">
                        <thead>
                            <tr>
                                <th style="text-align:left; border: 1px solid black;">Advance Payment Amount</th>
                                <th style="text-align:center; border: 1px solid black;">Advance Payment Date</th>
                                <th style="text-align:center; border: 1px solid black;">Installment Plan</th>
                                <th style="text-align:right; border: 1px solid black;">Installment Amount</th>
                                <th style="text-align:center; border: 1px solid black;">First Installment Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="text-align:left; border: 1px solid black;">
                                    <span t-esc="sum(doc.down_payment_amt_ids.mapped('amount'))" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                                <td style="text-align:center; border: 1px solid black;">
                                    <t t-set="first_down_payment" t-value="doc.down_payment_amt_ids and doc.down_payment_amt_ids[0]"/>
                                    <span t-if="first_down_payment" t-esc="first_down_payment.due_date" t-options='{"widget": "date"}'/>
                                    <span t-else="">N/A</span>
                                </td>
                                <td style="text-align:center; border: 1px solid black;">
                                    <span t-esc="doc.tenure"/>
                                    <t t-if="doc.tenure_plan == 'month'"> Months - Monthly</t>
                                    <t t-elif="doc.tenure_plan == 'quater'"> Quarters - Quarterly</t>
                                    <t t-elif="doc.tenure_plan == 'days'"> Days - Daily</t>
                                    <t t-else=""> <span t-esc="doc.tenure_plan"/></t>
                                </td>
                                <td style="text-align:right; border: 1px solid black;">
                                    <span t-esc="doc.installment_amt" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                                <td style="text-align:center; border: 1px solid black;">
                                    <span t-esc="doc.first_installment_date" t-options='{"widget": "date"}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </xpath>
<!--        <xpath expr="//span[@name='order_note']" position="replace"/>-->
        <xpath expr="//p[@t-if='not is_html_empty(doc.payment_term_id.note)']" position="replace"/>
        <xpath expr="//p[@id='fiscal_position_remark']" position="replace"/>
    </template>
</odoo>

