<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment Category Approver -->
    <record id="view_payroll_category_approver_list" model="ir.ui.view">
        <field name="name">payroll.category.approver.tree</field>
        <field name="model">payroll.category.approver</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                 <field name="existing_user_ids" column_invisible="True"/>
                <field name="company_id" column_invisible="True"/>
                <field name="sequence" widget="handle" />
                <field name="user_id" options="{'no_create': True}"/>
                <field name="required" string="Required"/>
            </list>
        </field>
    </record>
</odoo>
