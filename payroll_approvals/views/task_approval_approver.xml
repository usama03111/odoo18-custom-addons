<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_payroll_approval_approver_list" model="ir.ui.view">
        <field name="name">payroll.approval.approver.list</field>
        <field name="model">payroll.approval.approver</field>
        <field name="arch" type="xml">
            <list>
                 <field name="existing_request_user_ids" invisible="1"/>
                <field name="user_id"/>
                <field name="status"/>
                <field name="sequence"/>
                <field name="required"/>
            </list>
        </field>
    </record>

    <record id="view_payroll_approval_approver_form" model="ir.ui.view">
        <field name="name">payroll.approval.approver.form</field>
        <field name="model">payroll.approval.approver</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                         <field name="existing_user_ids" invisible="1"/>
                        <field name="user_id"/>
                        <field name="task_id"/>
                        <field name="status"/>
                        <field name="sequence"/>
                        <field name="required"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
