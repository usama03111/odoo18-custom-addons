<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cancel_wizard_reason_form_view_payroll" model="ir.ui.view">
            <field name="name">payroll.refuse.wizard.reason</field>
            <field name="model">payroll.refuse.wizard.reason</field>
            <field name="arch" type="xml">
                <form string="Refusal Reason">
                    <sheet>
                        <group>
                            <field name="reason" string="Reason"/>
                        </group>
                        <footer>
                            <button name="action_refuse" string="Refuse" type="object" default_focus="1"
                                    class="oe_highlight"/>
                            <button string="Cancel" class="oe_link" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="cancel_wizard_reason_action_view_payroll" model="ir.actions.act_window">
            <field name="name">Cancel Reason</field>
            <field name="res_model">payroll.refuse.wizard.reason</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="payroll_approvals.cancel_wizard_reason_form_view_payroll"/>
        </record>

    </data>
</odoo>
