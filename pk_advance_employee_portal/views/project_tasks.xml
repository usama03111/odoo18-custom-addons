<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <!--                     employee weekly/schedule form view template            -->

    <template id="project_tasks_temp_id" name="Project Task View">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>My Tasks</h3>
                    <a href="/" class="btn btn-primary">
                        <i class="fa fa-plus"/>
                        New Task Request
                    </a>
                </div>
                <form method="get" class="mb-4">
                    <div class="row">
                        <div class="col-md-4">
                            <input type="text" name="search" class="form-control" t-att-value="search"
                                   placeholder="Search tasks..."/>
                        </div>
                        <div class="col-md-3">
                            <select name="search_in" class="form-select">
                                <t t-foreach="search_input_values.items()" t-as="sval">
                                    <option t-att-value="sval[0]" t-att-selected="search_in == sval[0]">
                                        <t t-esc="sval[1]['label']"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary" type="submit">Search</button>
                        </div>
                    </div>
                </form>

                <t t-if="checkouts">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Project Name</th>
                                <th>Task Name</th>
                                <th>Assignees</th>
                                <th>Task Description</th>
                                <th>Milestone</th>
                                <th>Deadline</th>
                                <th>Stage</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="checkouts" t-as="doc">
                                <td>
                                    <span t-field="doc.project_id.name"/>
                                </td>
                                <td>
                                    <span t-field="doc.name"/>
                                </td>


                                <td>
                                    <t t-foreach="doc.user_ids" t-as="user" t-separator=", ">
                                        <span t-esc="user.name"/>
                                    </t>

                                </td>
                                <td>
                                    <span t-field="doc.description" t-options="{'widget': 'html'}"/>
                                </td>
                                <td>
                                    <span t-field="doc.milestone_id.name"/>
                                </td>

                                <td>
                                    <span t-field="doc.date_deadline"/>
                                </td>
                                <td>
                                    <span t-field="doc.stage_id.name"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </t>

                <t t-else="">
                    <div class="alert alert-warning" role="alert">
                        No Record found.
                    </div>
                </t>
            </div>
        </t>
    </template>


</odoo>