<odoo>
<template id="portal_leave_create_template" name="Leave Request Form">
    <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_create_leaves" t-value="'Request New Leave'" />
         <a href="/employee/leaves" class="btn btn-secondary ml-2">Back</a>
        <div class="container mt-4 mb-5">
            <h3 class="mb-3">Request New Leave</h3>
            <form action="/my/leaves/create" method="POST" class="oe_website_form form-horizontal">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="form-group row">
                    <label for="leave_type_id" class="col-sm-3 col-form-label">Leave Type</label>
                    <div class="col-sm-9">
                       <select name="leave_type" class="form-control" required="required">
                        <option value="">Select Type</option>
                        <t t-foreach="request.env['hr.leave.type'].sudo().search([])" t-as="lt">
                            <option t-att-value="lt.id"><t t-esc="lt.name" /></option>
                        </t>
                    </select>

                    </div>
                </div>

                <div class="form-group row">
                    <label for="request_date_from" class="col-sm-3 col-form-label">From Date</label>
                    <div class="col-sm-9">
                        <input type="date" name="request_date_from" class="form-control" required="required"/>
                    </div>
                </div>

                <div class="form-group row">
                    <label for="request_date_to" class="col-sm-3 col-form-label">To Date</label>
                    <div class="col-sm-9">
                        <input type="date" name="request_date_to" class="form-control" required="required"/>
                    </div>
                </div>

                <div class="form-group row">
                    <label for="reason" class="col-sm-3 col-form-label">Reason</label>
                    <div class="col-sm-9">
                        <textarea name="reason" class="form-control" rows="3" placeholder="Optional..."> </textarea>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="offset-sm-3 col-sm-9">
                        <button type="submit"  class="btn btn-success">Submit Leave Request</button>
                        <a href="/employee/leaves" class="btn btn-secondary ml-2">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </t>
</template>
</odoo>
