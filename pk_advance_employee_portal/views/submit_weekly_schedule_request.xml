<odoo>
<template id="weekly_schedule__template" name="Leave Request Form">
    <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_create_leaves" t-value="'Request New Leave'" />
         <a href="/weekly/schedule" class="btn btn-secondary ml-2">Back</a>
        <div class="container mt-4 mb-5">
            <h3 class="mb-3">Request New Schedule</h3>
            <form action="/weekly-schedule/request" method="POST" class="oe_website_form form-horizontal">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="form-group row">
                    <label for="resource_id" class="col-sm-3 col-form-label">Resource</label>
                    <div class="col-sm-9">
                       <select name="resource_id" class="form-control" required="required">
                        <option value="">Select Resource</option>
                        <t t-foreach="request.env['resource.resource'].sudo().search([])" t-as="lt">
                            <option t-att-value="lt.id"><t t-esc="lt.name" /></option>
                        </t>
                    </select>

                    </div>
                </div>

                <div class="form-group row">
                    <label for="start_datetime" class="col-sm-3 col-form-label">From Date</label>
                    <div class="col-sm-9">
                        <input type="date" name="start_datetime" class="form-control" required="required"/>
                    </div>
                </div>

                <div class="form-group row">
                    <label for="end_datetime" class="col-sm-3 col-form-label">To Date</label>
                    <div class="col-sm-9">
                        <input type="date" name="end_datetime" class="form-control" required="required"/>
                    </div>
                </div>

                <div class="form-group row">
                    <label for="role_id" class="col-sm-3 col-form-label">Role</label>
                    <div class="col-sm-9">
                       <select name="role_id" class="form-control" required="required">
                        <option value="">Select Role</option>
                        <t t-foreach="request.env['planning.role'].sudo().search([])" t-as="lt">
                            <option t-att-value="lt.id"><t t-esc="lt.name" /></option>
                        </t>
                    </select>

                    </div>
                </div>

                <div class="form-group row">
                    <label for="company_id" class="col-sm-3 col-form-label">Company</label>
                    <div class="col-sm-9">
                       <select name="company_id" class="form-control" required="required">
                        <option value="">Select Company</option>
                        <t t-foreach="request.env['res.company'].sudo().search([])" t-as="lt">
                            <option t-att-value="lt.id"><t t-esc="lt.name" /></option>
                        </t>
                    </select>

                    </div>
                </div>

                <div class="form-group row">
                    <div class="offset-sm-3 col-sm-9">
                        <button type="submit"  class="btn btn-success">Submit Request</button>
                        <a href="/weekly/schedule" class="btn btn-secondary ml-2">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </t>
</template>
</odoo>
