<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="pos_payment_method_reverse_journal" model="ir.ui.view">
            <field name="name">Pos Payment Method Jouranl Reverse</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='type']" position="after">
                    <field name="internal_pos_move" />
                    <field name="payment_mehtod" invisible="internal_pos_move == False"/>
                    <field name="pos_branch" invisible="internal_pos_move == False"/>
                </xpath>
            </field>
        </record>


        <record id="pos_payment_method_trans" model="ir.ui.view">
            <field name="name">Pos Payment Method</field>
            <field name="model">pos.payment.method</field>
            <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="internal_trans" />
                </xpath>
            </field>
        </record>

        <record id="pos_session_close" model="ir.ui.view">
            <field name="name">Pos Session</field>
            <field name="model">pos.session</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="create_move_cust" type="object" string="Close Session Custom"  invisible="state == 'closed'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>