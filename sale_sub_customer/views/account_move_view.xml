<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_sub_customer" model="ir.ui.view">
        <field name="name">account.move.form.sub.customer</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">

                <group col="2" invisible="move_type != 'out_invoice'">

                    <!-- Sub Customer Checkbox -->
                    <field name="has_sub_customer"
                           string="Has Sub Customer"/>

                    <!-- Sub Customer Field -->
                    <field name="sub_customer_id"
                           string="Sub Customer"
                           invisible="not has_sub_customer"/>

                </group>

            </xpath>

        </field>
    </record>
</odoo>
