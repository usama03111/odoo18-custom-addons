<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_sub_customer" model="ir.ui.view">
        <field name="name">sale.order.form.sub.customer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="has_sub_customer"/>
                <field name="sub_customer_id" invisible="not has_sub_customer"/>
            </xpath>
        </field>
    </record>
</odoo>
