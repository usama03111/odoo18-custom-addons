<?xml version ="1.0" encoding="utf-8" ?>

<odoo>

     <record forcecreate="True" id="project_task_overdue_notify" model="ir.cron">
            <field name="name">Project Task Overdue Notify</field>
            <field name="model_id" ref="model_sh_project_task_overdue_email"/>
            <field name="state">code</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="code">model.notify_employee_overdue_fun()</field>
            <field eval="True" name="active" />
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>


    <record id="project_task_overdue_email" model="sh.project.task.overdue.email">
        <field name="name">Email</field>
        <field name="company_id">1</field>
    </record>
</odoo>
