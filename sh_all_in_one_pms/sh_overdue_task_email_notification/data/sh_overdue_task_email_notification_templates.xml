<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="template_project_task_overdue_notify_email" model="mail.template">
    <field name="name">Project Task Overdue - Send Email</field>
    <field name="email_from"></field>
    <field name="email_to">{{ object.user_ids.email }}</field>
    <field name="subject">{{ object.company_id.name }} - Task Over Due Notification</field>
    <field name="model_id" ref="sh_all_in_one_pms.model_sh_project_task_overdue_email" />
    <field name="auto_delete" eval="False" />
    <field name="body_html" type="html">
      <div style="margin: 0px; padding: 0px;background: #ededed;">
        <table border="0" width="100%" cellpadding="0" bgcolor="#ededed" style="padding: 20px;background-color: #ededed;border-collapse: separate;width: 600px;margin: 0px auto;" summary="o_mail_notification">
          <tbody>
            <tr>
              <td align="center">
                <table width="590" border="0" cellpadding="0" bgcolor="#875A7B" style="min-width: 590px; background-color: rgb(135,90,123); padding: 20px; border-collapse:separate;">
                  <tr>
                    <td valign="middle">
                      <span style="font-size:20px; color:white; font-weight: bold;">
                                      Task Overdue Email Notification
                                  </span>
                    </td>
                    <td valign="middle" align="right">
                      <img src="/logo.png?company=${object.company_id.id}" style="padding: 0px; margin: 0px; height: auto; width: 80px;" alt="{{ object.company_id.name }}" />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td align="center">
                <div style="padding: 15px 25px;background: #fff;">
                  <table border="0" cellpadding="0" bgcolor="#ffffff" style="background-color: #fff;padding: 20px 10px;border-collapse: collapse;width: 100%;">
                    <tr>
                      <td colspan="3" valign="top" style="font-family:Arial,Helvetica,sans-serif; color: #555; font-size: 14px;">
                        <p>
		                              		Dear Employee <t t-out="object.user_ids.name"/>,
		           						</p>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding-bottom: 5px;">
                        <b style="font-size: 14px;">Overdue Task List</b>
                      </td>
                    </tr>
                    <tr>
                      <td width="33.33%" style="border: 1px solid gray;background-color:#875A7B;text-decoration: none; color: #fff;font-size: 15px;padding: 5px;">
						            	Project
						            </td>
                      <td width="33.33%" style="border: 1px solid gray;background-color:#875A7B;text-decoration: none; color: #fff;font-size: 15px;padding: 5px;">
						            	Task
						            </td>
                      <td width="33.33%" style="border: 1px solid gray;background-color:#875A7B;text-decoration: none; color: #fff;font-size: 15px;padding: 5px;">
						            	Deadline Date
						            </td>
                    </tr>
                    <t t-foreach="object.notify_ids" t-as="row">                    
                      <tr>
                        <td width="33.33%" style="border: 1px solid gray;padding: 5px;">
                          <span><t t-out="row.project_id"/></span>
                        </td>
                        <td width="33.33%" style="border: 1px solid gray;padding: 5px;">
                          <span><t t-out="row.name"/></span>
                        </td>
                        <td width="33.33%" style="border: 1px solid gray;padding: 5px;">
                          <span><t t-out="row.date_deadline"/></span>
                        </td>
                      </tr>
                    </t>
                  </table>
                </div>
              </td>
            </tr>
            <tr>
              <td align="center">
                <table width="590" border="0" cellpadding="0" bgcolor="#875A7B" style="min-width: 590px; background-color: rgb(135,90,123); padding: 20px; border-collapse:separate;">
                  <tr>
                    <td valign="middle" align="left" style="color: #fff; padding-top: 10px; padding-bottom: 10px; font-size: 14px;">
                      <t t-out="object.company_id.name"/>
                      <br />
                      <t t-out="object.company_id.phone or ''"/>                     
                    </td>
                    <td valign="middle" align="right" style="color: #fff; padding-top: 10px; padding-bottom: 10px; font-size: 14px;">
                      <t t-if="object.company_id.email">
                        <a href="mailto:${object.company_id.email}" style="text-decoration:none; color: white;"><t t-out="object.company_id.email"/></a>
                        <br />
                      </t>
                      <t t-if="object.company_id.website">
                      <a href="${object.company_id.website}" style="text-decoration:none; color: white;">
                              <t t-out="object.company_id.website"/>
                      </a>
                      </t>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </field>
  </record>
</odoo>	