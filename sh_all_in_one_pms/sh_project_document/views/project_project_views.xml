<odoo>
    <record id="project_project_form_view_inherit" model="ir.ui.view">
        <field name="name">project.project.form.view.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="open_document" context="{'default_project_id': id}" class="oe_stat_button"
                        icon="fa-files-o" type="object" groups="sh_all_in_one_pms.group_sh_project_document">
                    <field name="document_count" widget="statinfo" string="Documents"/>
                </button>
            </div>
        </field>
    </record>

