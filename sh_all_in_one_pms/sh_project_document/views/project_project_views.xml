     <record id="project_kanban_view_inherit" model="ir.ui.view">
            <field name="name">project.project.order.kanban.view.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//span[contains(@class, 'fw-bold') and contains(@class, 'fs-4')]" position="after">
                    <span t-if="record.document_count.value &gt; 0" class="badge badge-pill" groups="sh_all_in_one_pms.group_sh_project_document">
                        <i class="fa fa-fw fa-files-o" role="img" aria-label="Files" title="Files"/>
                        <t t-esc="record.document_count.value"/>
                    </span>
                </xpath>
            </field>
        </record>
