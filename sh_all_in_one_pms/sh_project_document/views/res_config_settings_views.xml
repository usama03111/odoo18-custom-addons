<?xml version ="1.0" encoding="utf-8" ?>
<odoo>
    <record id="sh_res_config_settings_project_document_form_inherit" model="ir.ui.view">
        <field name="name">res.config.setting.customer.document.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="project.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='project_time']" position="before">
                <div id="project_document" groups="sh_all_in_one_pms.group_sh_project_document">
                    <h2>Project Order Document</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="sh_project_expiry_notification" />
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="sh_project_expiry_notification" string="Document Expiry Notification" />
                                <div class="text-muted">
                                    Set Mail Document Expiry Notification
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False" >
                            <div class="o_setting_left_pane">
                                <field name="sh_project_on_date_notify" />
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="sh_project_on_date_notify" string="On Expiry Date Notification" />
                                <div class="text-muted">
                                    On Document Expiry Date Notification
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane">
                                <field name="sh_is_project_notify_customer" />
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="sh_is_project_notify_customer" string="Notify Customer" />
                                <div class="text-muted">
                                    Notify Customer
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_attachment_email" string="Notify Email to" /><br />
                                <field name="project_attachment_email" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_before_first_notify" string="Notify Before Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_before_first_notify" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_after_first_notify" string="Notify After Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_after_first_notify" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_before_second_notify" string="Notify Before Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_before_second_notify" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_after_second_notify" string="Notify After Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_after_second_notify" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_before_third_notify" string="Notify Before Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_before_third_notify" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" invisible="sh_project_expiry_notification == False">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="project_enter_after_third_notify" string="Notify After Expiry Date" class="o_light_label" />
                                <field class="col-2" name="project_enter_after_third_notify" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
