<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_project_priority_inherit_view_form" model="ir.ui.view">
        <field name="name">project.project.inherit.view.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="enable_project_priority" invisible="1"/>
                <field name="sh_priority" widget="priority" invisible="not enable_project_priority"/>
                <field name="default_added_to_task" invisible="not enable_project_priority"/>
            </field>
        </field>
    </record>

    <record id="project_project_priority_inherit_view_tree" model="ir.ui.view">
        <field name="name">project.project.inherit.view.tree</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="enable_project_priority" column_invisible="1"/>
                <field name="sh_priority" widget="priority" invisible="not enable_project_priority"/>
            </field>
        </field>
    </record>

    <record id="project_project_priority_inherit_view_search" model="ir.ui.view">
        <field name="name">project.project.inherit.view.filter</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter" />
        <field name="arch" type="xml">
            <xpath expr="//group//filter[2]" position="after">
                <filter string="Priority" name="priority" context="{'group_by': 'sh_priority'}"/>
            </xpath>
        </field>
    </record>

    <record id="project_project_priority_inherit_view_kanban" model="ir.ui.view">
        <field name="name">project.project.inherit.view.kanban</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//kanban//templates//t[2]//field[@name='tag_ids']" position="after">
                <field name="enable_project_priority" invisible="1"/>
                <field name="sh_priority" widget="priority" invisible="not enable_project_priority"/>
            </xpath>
        </field>
    </record>
</odoo>
