    <record id="project_task_priority_inherit_view_kanban" model="ir.ui.view">
    <field name="name">project.task.inherit.view.kanban</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_kanban"/>
    <field name="arch" type="xml">

        <!-- Insert after the properties field -->
        <xpath expr="//main/field[@name='task_properties']" position="after">
            <field name="enable_project_priority" invisible="1"/>
            <field name="sh_priority" widget="priority" invisible="not enable_project_priority"/>
        </xpath>

    </field>
</record>


