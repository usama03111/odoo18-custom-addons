<record id="sh_project_task_inherit_view_kanban" model="ir.ui.view">
    <field name="name">sh.project.task.inherit.view.kanban</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_kanban"/>
    <field name="arch" type="xml">
        <!-- Still valid: adding field under the record -->
        <field name="partner_id" position="after">
            <field name="sh_project_team_id"/>
        </field>

        <!-- New XPath targeting the div with partner_id inside -->
        <xpath expr="//div[contains(@class, 'd-flex') and contains(@class, 'flex-column')]" position="inside">
            <t t-if="record.sh_project_team_id.value">
                <h6>
                    <t t-esc="record.sh_project_team_id.value"/>
                </h6>
            </t>
        </xpath>
    </field>
</record>



