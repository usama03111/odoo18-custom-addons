<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sh_task_checklist_form_view" model="ir.ui.view">
        <field name="name">task.checklist.form</field>
        <field name="model">task.checklist</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company" />
                        </group>
                        <group>
                            <field name="description" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sh_project_task_checklist_tree_view" model="ir.ui.view">
        <field name="name">task.checklist.tree</field>
        <field name="model">task.checklist</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_menu_task_checklist">
        <field name="name">Task Checklist</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">task.checklist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_task_checklist" name="Task Checklist" action="action_menu_task_checklist" parent="project.menu_project_config" groups="sh_all_in_one_pms.group_enable_task_checklist"/>
    <menuitem id="menu_import_task_checklist" name="Import Task Checklist" action="sh_all_in_one_pms.sh_import_task_cl_action" parent="project.menu_project_config" groups="sh_all_in_one_pms.group_enable_task_checklist"/>

</odoo>
