<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="sh_project_task_custom_checklist_tree_view_inherit" model="ir.ui.view">
        <field name="name">project.task.custom.checklist.tree</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2" />
        <field name="arch" type="xml">
            <field name="user_ids" position="after">
                <field name="custom_checklist" widget="progressbar" optional="show" groups="sh_all_in_one_pms.group_enable_task_custom_checklist"/>
            </field>
        </field>
    </record>
    <record id="sh_project_task_checklist_kanban_view_inherit" model="ir.ui.view">
        <field name="name">project.task.custom.checklist.kanban</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban" />
        <field name="arch" type="xml">
<!--            <xpath expr="//div[hasclass('o_kanban_record_body')]" position="before">-->
            <xpath expr="//main/field[@name='tag_ids']" position="before">
                <div>
                    <field name="custom_checklist" string="Checklist" widget="percentpie" groups="sh_all_in_one_pms.group_enable_task_custom_checklist"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="sh_project_task_custom_checklist_search_view_inherit" model="ir.ui.view">
        <field name="name">project.task.checklist.search</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form" />
        <field name="arch" type="xml">
            <!-- <field name="enable_task_custom_checklist" invisible="1" /> -->
            <filter name="message_needaction" position="after">
                <filter string="Complete Checklist" name="complete_state" domain="[('task_complete_state','=', True)]" groups="sh_all_in_one_pms.group_enable_task_custom_checklist" />
                <filter string="Uncompleted Checklist" name="uncomplete_state" domain="[('task_complete_state','=', False)]" groups="sh_all_in_one_pms.group_enable_task_custom_checklist"/>
            </filter>
        </field>
    </record>

    <record id="sh_project_task_custom_checklist_form_view_inherit" model="ir.ui.view">
        <field name="name">project.task.custom.checklist.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="custom_checklist" string="Checklist" groups="sh_all_in_one_pms.group_enable_task_custom_checklist">
                    <button name="%(action_menu_task_custom_checklist)d" type="action" class="oe_stat_button" style="height: 40px; background: White;" >
                        <field name="custom_checklist" string="Checklist Completed" widget="percentpie" style="height: 30px; background: White;" />
                    </button>
                    <span style="padding-left:50px;">Check List </span>
                    <field name="check_list_ids" widget="many2many_tags" />
                    <field name="task_complete_state" invisible="1" />
                    <field name="custom_checklist_ids">
                        <list editable="bottom">
                            <field name="name" />
                            <field name="description" />
                            <field name="updated_date" />
                            <field name="company_id" column_invisible="1" />
                            <field name="state" widget="badge" decoration-success="state == 'completed'" decoration-danger="state=='cancelled'" decoration-mute="state == 'new'" />
                            <button string="Complete" name="btn_check" type="object" icon="fa-check" invisible="state == 'completed'" />
                            <button string="Cancel" name="btn_close" type="object" icon="fa-close" invisible="state == 'cancelled'" />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
