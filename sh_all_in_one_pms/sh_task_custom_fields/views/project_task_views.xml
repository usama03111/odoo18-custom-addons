<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sh_project_task_dynamic_tab_form_view_inherit" model="ir.ui.view">
        <field name="name">project.task.tab.fields.form.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
            <xpath expr="//form//header" position="inside">
                <button name="%(sh_action_project_task_custom_tab)d" groups="sh_all_in_one_pms.group_task_custom_field" string="Add Custom Tab" type="action" class="oe_highlight" />
            </xpath>
        </field>
    </record>

    <record id="sh_project_task_dynamic_fields_form_view_inherit" model="ir.ui.view">
        <field name="name">project.task.dynamic.fields.form.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
            <xpath expr="//form//header" position="inside">
                <button name="%(sh_project_task_dynamic_fields)d" groups="sh_all_in_one_pms.group_task_custom_field" string="Add Custom Field" type="action" class="oe_highlight" />
                <!-- groups="sh_task_custom_fields.group_task_custom_field"/> -->
            </xpath>
        </field>
    </record>

</odoo>