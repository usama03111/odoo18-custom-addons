<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend Task Form View -->
        <record id="view_task_form_inherit_approval" model="ir.ui.view">
            <field name="name">project.task.form.inherit.approval</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <!--                            invisible="requires_approval == False or approval_state != 'draft'"-->

                    <button name="action_submit_for_approval"
                            string="Submit for Approval"
                            type="object"
                            class="oe_highlight"
                    />
                    <!--                            invisible="requires_approval == False or approval_state != 'waiting'"-->

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="oe_highlight"
                    />
                    <!--                            invisible="requires_approval == False or approval_state != 'waiting'"-->

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                    />
                    <field name="approval_state" widget="statusbar"
                           statusbar_visible="draft,waiting,approved,rejected"/>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <!--                          invisible="requires_approval == False"-->

                    <page string="Approvals"
                    >
                        <group>
                            <group>
                                <field name="requires_approval" invisible="1"/>
                                <field name="is_approval_user" invisible="1"/>
                                <field name="approval_config_id"/>
                                <field name="level"
                                       invisible="requires_approval != 'waiting'"
                                />
                            </group>
                            <group>
                                <field name="user_ids" widget="many2many_tags"
                                       invisible="approval_state != 'waiting'"

                                />
                                <field name="group_ids" widget="many2many_tags"
                                       invisible="approval_state != 'waiting'"

                                />
                            </group>
                        </group>
                        <group string="Approval History"
                               invisible="approval_info_line == []"

                        >
                            <field name="approval_info_line" readonly="1">
                                <list>
                                    <field name="level"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="group_ids" widget="many2many_tags"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="approved_by"/>
                                </list>
                            </field>
                        </group>
                        <group string="Rejection Information"
                               invisible="approval_state != 'rejected'">
                            <group>
                                <field name="reject_by"/>
                                <field name="rejection_date"/>
                            </group>
                            <group>
                                <field name="reject_reason"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Add Approval State Filter in Task Search View -->
        <record id="view_task_search_inherit_approval" model="ir.ui.view">
            <field name="name">project.task.search.inherit.approval</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_search_form"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='my_tasks']" position="after">
                    <separator/>
                    <filter string="My Approval Tasks" name="my_approval_tasks"
                            domain="[('is_approval_user', '=', True)]"/>
                    <filter string="Waiting Approval" name="waiting_approval"
                            domain="[('approval_state', '=', 'waiting')]"/>
                    <filter string="Approved" name="approved" domain="[('approval_state', '=', 'approved')]"/>
                    <filter string="Rejected" name="rejected" domain="[('approval_state', '=', 'rejected')]"/>
                </xpath>
                <xpath expr="//group" position="inside">
                    <filter string="Approval State" name="group_by_approval_state"
                            context="{'group_by': 'approval_state'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo> 