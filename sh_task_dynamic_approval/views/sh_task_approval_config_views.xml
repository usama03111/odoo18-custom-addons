<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Task Approval Configuration Tree View -->
        <record id="sh_task_approval_config_tree_view" model="ir.ui.view">
            <field name="name">sh.task.approval.config.tree</field>
            <field name="model">sh.task.approval.config</field>
            <field name="arch" type="xml">
                <list string="Task Approval Configuration">
                    <field name="name"/>
                    <field name="project_ids" widget="many2many_tags"/>
                    <field name="stage_ids" widget="many2many_tags"/>
                    <field name="company_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <!-- Task Approval Configuration Form View -->
        <record id="sh_task_approval_config_form_view" model="ir.ui.view">
            <field name="name">sh.task.approval.config.form</field>
            <field name="model">sh.task.approval.config</field>
            <field name="arch" type="xml">
                <form string="Task Approval Configuration">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="company_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="project_ids" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="stage_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Approval Levels">
                                <field name="task_approval_line">
                                    <list editable="bottom">
                                        <field name="level"/>
                                        <field name="approve_by"/>
                                        <field name="user_ids" widget="many2many_tags" required="approve_by == 'user'" invisible="approve_by == 'group'" />
                                        <field name="group_ids" widget="many2many_tags" required="approve_by == 'group'" invisible="approve_by == 'user'" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Task Approval Configuration Search View -->
        <record id="sh_task_approval_config_search_view" model="ir.ui.view">
            <field name="name">sh.task.approval.config.search</field>
            <field name="model">sh.task.approval.config</field>
            <field name="arch" type="xml">
                <search string="Task Approval Configuration">
                    <field name="name"/>
                    <field name="project_ids"/>
                    <field name="stage_ids"/>
                    <field name="company_ids"/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="group_by_project" context="{'group_by': 'project_ids'}"/>
                        <filter string="Stage" name="group_by_stage" context="{'group_by': 'stage_ids'}"/>
                        <filter string="Company" name="group_by_company" context="{'group_by': 'company_ids'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Task Approval Configuration Action -->
        <record id="action_task_approval_config" model="ir.actions.act_window">
            <field name="name">Task Approval Configuration</field>
            <field name="res_model">sh.task.approval.config</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first task approval configuration!
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_task_approval_config"
                  name="Task Approvals"
                  parent="project.menu_project_config"
                  sequence="5"/>

        <menuitem id="menu_task_approval_config_settings"
                  name="Approval Configuration"
                  parent="menu_task_approval_config"
                  action="action_task_approval_config"
                  sequence="1"/>
    </data>
</odoo> 