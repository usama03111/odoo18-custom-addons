<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherit the survey user input line form view -->
    <record id="view_survey_user_input_line_form_inherit" model="ir.ui.view">
        <field name="name">survey.user_input_line.form.inherit.answer.image</field>
        <field name="model">survey.user_input.line</field>
        <field name="inherit_id" ref="survey.survey_user_input_line_view_form"/>
        <field name="arch" type="xml">

            <!-- Add your fields below the suggested_answer_id -->
            <xpath expr="//sheet" position="after">
                <chatter open_attachments="True"/>
            </xpath>
        </field>
    </record>

    <record id="survey_user_input_line_view_form_inherit_attachment_condition" model="ir.ui.view">
        <field name="name">survey.user_input.line.view.form.inherit.attachment.condition</field>
        <field name="model">survey.user_input.line</field>
        <field name="inherit_id" ref="survey.survey_user_input_line_view_form"/>
        <field name="arch" type="xml">
            <!-- Locate the value_text_box field in the original form -->
            <xpath expr="//field[@name='value_text_box']" position="attributes">
                <attribute name="invisible">answer_type not in ['text_box', 'attachment']</attribute>
            </xpath>
        </field>
    </record>



    <record id="view_survey_line_chatter_popup" model="ir.ui.view">
        <field name="name">survey.line.view.form.inherit</field>
        <field name="model">survey.user_input</field>
        <field name="inherit_id" ref="survey.survey_user_input_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_input_line_ids']//list//field[@name='answer_score']" position="after">
                <button name="action_open_popup_form" type="object" icon="fa-eye" title="View Details"
                        class="btn-link"/>
            </xpath>
        </field>
    </record>

</odoo>
