<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--Scrum Sprint-->

        <!--sprint tree view-->
        <record id="view_ps_sprint_tree" model="ir.ui.view">
            <field name="name">project.scrum.sprint.tree</field>
            <field name="model">project.scrum.sprint</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Scrum Sprint">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="scrum_master_id"/>
                    <field name="product_owner_id"/>
                    <field name="date_start"/>
                    <field name="date_stop"/>
                    <field name="planned_hours" widget="float_time"/>
                    <field name="effective_hours" widget="float_time"/>
                    <field name="progress" widget="progressbar"/>
                    <field name="date_duration"/>
                    <field name="stage_id"/>
                </list>
            </field>
        </record>

        <!--sprint form view-->
        <record id="view_ps_sprint_form" model="ir.ui.view">
            <field name="name">project.scrum.sprint.form</field>
            <field name="model">project.scrum.sprint</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Scrum Sprint">
                    <!--Header stages-->
                    <header>
                        <field name="stage_id" widget="statusbar" options="{'clickable': '1', 'fold_field': 'fold'}"/>
                    </header>
                    <sheet string="Sprint">
                        <h1>
                            <field name="name" placeholder="Sprint..." class="oe_inline"/>
                        </h1>
                        <button class="oe_inline oe_stat_button" type="action" icon="fa-tasks"
                                name="%(action_ps_sprint_backlog)d" string="Backlog"
                                context="{'default_project_id': project_id}">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>

                        <group>
                            <group>
                                <field name="project_id"/>

                                <field name="progress" widget="progressbar"/>
                                <field name="planned_hours" widget="float_time"/>
                                <field name="effective_hours" widget="float_time"/>
                            </group>
                            <group>
                                <label for="date_start" string="Planned Date"/>
                                <div name="dates" class="o_row">
                                    <field name="date_start" widget="daterange"
                                           options='{"related_end_date": "date_stop"}'/>
                                    <i class="fa fa-long-arrow-right mx-2 oe_edit_only" aria-label="Arrow icon"
                                       title="Arrow"/>
<!--                                    <i class="fa fa-long-arrow-right mx-2 oe_read_only" aria-label="Arrow icon"-->
<!--                                       title="Arrow"-->
<!--                                       attrs="{'invisible': [('date_start', '=', False), ('date_stop', '=', False)]}"/>-->
                                    <i class="fa fa-long-arrow-right mx-2 oe_read_only" aria-label="Arrow icon"
                                       title="Arrow"
                                       invisible="date_start ==  False or date_stop   == False"/>
                                    <field name="date_stop" widget="daterange"
                                           options='{"related_start_date": "date_start"}'/>
                                </div>
                                <field name="date_duration"/>
                            </group>
                        </group>

                        <notebook colspan="5">
                            <!--User Stories-->
                            <page string="User Story">
                                <field name="us_ids" context="{
                                        'default_project_id': project_id,
                                        'default_sprint_id': id,
                                        }">
                                    <list>
                                        <field name="name"/>
                                        <field name="actor_ids"/>
                                        <field name="project_id"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Review">
                                <!--page for review-->
                                <group>
                                    <field name="review"/>
                                </group>
                                <group col="1">
                                    <field name="task_ids" string="Task" context="{
                                            'default_project_id': project_id,
                                            'default_sprint_id': id,
                                            'default_us_ids': us_ids,
                                            }">
                                        <list>
                                            <field name="sequence" widget="handle"/>
                                            <field name="priority"/>
                                            <field name="name"/>
                                            <field name="user_id"/>
                                            <field name="date_deadline"/>
                                            <field name="stage_id"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Retrospective">
                                <!--page for retropective-->
                                <field name="retrospective"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!--sprint kanban view-->
        <record id="ps_sprint_view_kanban" model="ir.ui.view">
            <field name="name">project.scrum.sprint.kanban</field>
            <field name="model">project.scrum.sprint</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_content oe_kanban_global_click o_kanban_get_form">
                                <div class="row">
                                    <div class="col-12">
                                        <strong>
                                            <field name="name" string="Sprint Name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-8">
                                        <field name="project_id" string="project"/>
                                    </div>

                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

                <!-- filter -->
        <record id="view_project_scrum_sprint_filter" model="ir.ui.view">
            <field name="name">project.scrum.sprint.select</field>
            <field name="model">project.scrum.sprint</field>
            <field name="arch" type="xml">
                <search string="Search Sprint">
                    <field name="name" string="Sprint"/>
                    <field name="project_id" string="Project"/>
                    <field name="stage_id" string="By Stage"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="Project" context="{'group_by': 'project_id'}"/>
                        <filter string="Stage" name="groupby_stage" context="{'group_by': 'stage_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <!--access to all sprint tree view-->
        <record id="action_ps_sprint_all" model="ir.actions.act_window">
            <field name="name">Sprints</field>
            <field name="res_model">project.scrum.sprint</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="view_id" ref="ps_sprint_view_kanban"/>
            <field name="context">{'search_default_groupby_stage': 1}</field>
            <field name="search_view_id" ref="view_project_scrum_sprint_filter"/>

            <field name="help">
                Agile scrum methodology is a project management system that
                relies on incremental development. Each iteration consists of two- to four-week sprints, where the goal
                of each sprint is to build the most important features first and come out with a potentially deliverable
                product
            </field>
        </record>


        <!--access to current sprint tree view-->
        <record id="action_ps_sprint_current" model="ir.actions.act_window">
            <field name="name">Sprints</field>
            <field name="res_model">project.scrum.sprint</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="context">{'search_default_groupby_stage': 1}</field>
            <field name="view_id" ref="view_ps_sprint_tree"/>
            <field name="search_view_id" ref="view_project_scrum_sprint_filter"/>

            <field name="context">
                {
                'search_default_project_id': [active_id],
                'default_project_id': active_id,
                'search_default_group_by_sprint': 1,
                'active_test': False,
                }
            </field>
            <field name="help">
                Agile scrum methodology is a project management system that
                relies on incremental development. Each iteration consists of two- to four-week sprints, where the goal
                of each sprint is to build the most important features first and come out with a potentially deliverable
                product
            </field>
        </record>


    </data>
</odoo>
