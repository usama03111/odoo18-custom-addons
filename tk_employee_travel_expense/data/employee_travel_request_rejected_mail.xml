<odoo>
    <!-- Email template for send notification employee travel request rejected-->
    <record id="email_template_travel_request_rejected" model="mail.template">
        <field name="name">Employee Travel Request Rejected</field>
        <field name="model_id" ref="tk_employee_travel_expense.model_employee_travel_request"/>
        <field name="email_from">{{ (object.company_id.email) }}</field>
        <field name="email_to">{{ object.employee_id.user_id.email }}</field>
        <field name="subject">Rejection Notice for Travel Request {{ object.sequence }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear,
                    <t t-out="object.employee_id.name or ''"/>
                </p>
                <p>We regret to inform you that your travel request
                    <strong>
                        <t t-out="object.sequence"/>
                    </strong>
                    has been <strong>rejected</strong>.
                </p>
                <p>
                    <strong>Rejection Reason:</strong>
                    <t t-out="object.request_reject_reason"/>
                </p>
                <t t-if="object.closing_notes">
                    <p>
                        <strong>Closing Notes:</strong>
                        <t t-out="object.closing_notes"/>
                    </p>
                </t>
                <p>If you have any questions or need further clarification, please contact your manager or the HR
                    department.
                </p>
                <p>Thank you.</p>
            </div>
        </field>
    </record>
</odoo>
