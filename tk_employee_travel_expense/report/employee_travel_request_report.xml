<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Template-->
    <template id="employee_travel_request_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 style="border-bottom:1px solid black;padding-bottom:10px;">Employee Travel Request
                            -
                            <span t-field="o.sequence"/>
                        </h2>
                        <br/>
                        <h6
                                style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                            <i class="fa fa-user-o me-1 ms-2" aria-hidden="true"/>
                            Employee Information
                        </h6>
                        <table class="table table-borderless">
                            <tr>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td style="width:35%;">
                                                Employee
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:63%;">
                                                <strong>
                                                    <span t-field="o.employee_id.name"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:35%;">
                                                Department
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:63%;">
                                                <strong>
                                                    <span t-field="o.department_id"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Manager
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.manager_id.name"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr t-if="o.phone">
                                            <td style="width:28%;">
                                                Phone
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.phone"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr t-if="o.mobile">
                                            <td style="width:28%;">
                                                Mobile
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.mobile"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr t-if="o.email">
                                            <td style="width:28%;">
                                                Email
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.email"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        <h6
                                style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                            <i class="fa fa-calendar-o me-1 ms-2" aria-hidden="true"/>
                            Travel Information
                        </h6>
                        <table class="table table-borderless">
                            <tr>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td style="width:28%;">
                                                Title
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.travel_information"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Project
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.project_id.name"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Travel Mode
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.travel_mode_id"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td style="width:28%;">
                                                Duration
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.request_departure_date"/>
                                                    <span style="margin-left:5px;margin-right:5px;">to</span>
                                                    <span t-field="o.request_return_date"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Days
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <span t-field="o.trip_days"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        <table class="table table-borderless">
                            <tr>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr style="padding:0px;">
                                            <td colspan="3" style="margin:0px;padding-left:0px;">
                                                <h6
                                                        style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                                                    <i class="fa fa-sign-out me-1 ms-2" aria-hidden="true"/>
                                                    From
                                                </h6>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Address
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <t t-if="o.from_street">
                                                        <t t-esc="o.from_street"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.from_street2">
                                                        <t t-esc="o.from_street2"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.from_city or o.from_zip">
                                                        <t t-esc="o.from_city"/>
                                                        <t t-if="o.from_city and o.from_zip">
                                                            <span>-</span>
                                                        </t>
                                                        <t t-esc="o.from_zip"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.state_id.name">
                                                        <t t-esc="o.state_id.name"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.country_id.name">
                                                        <t t-esc="o.country_id.name"/>
                                                    </t>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width:50%;padding:0px;">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td colspan="3" style="margin:0px;padding-right:0px;">
                                                <h6 style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                                                    <i class="fa fa-sign-in me-1 ms-2" aria-hidden="true"/>
                                                    To
                                                </h6>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:28%;">
                                                Address
                                            </td>
                                            <td style="width:2%;">
                                                :
                                            </td>
                                            <td style="width:70%;">
                                                <strong>
                                                    <t t-if="o.to_street">
                                                        <t t-esc="o.from_street"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.to_street2">
                                                        <t t-esc="o.to_street2"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.to_city or o.to_zip">
                                                        <t t-esc="o.to_city"/>
                                                        <t t-if="o.to_city and o.to_zip">
                                                            <span>-</span>
                                                        </t>
                                                        <t t-esc="o.to_zip"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.to_state_id.name">
                                                        <t t-esc="o.to_state_id.name"/>
                                                        <br/>
                                                    </t>
                                                    <t t-if="o.to_country_id.name">
                                                        <t t-esc="o.to_country_id.name"/>
                                                    </t>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        <t t-if="o.is_advance_payment">
                            <h6
                                    style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                                <i class="fa fa-credit-card me-1 ms-2" aria-hidden="true"/>
                                Advance Payment Register
                            </h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td style="width:50%;padding:0px;">
                                        <table class="table table-borderless">
                                            <tr>
                                                <td style="width:38%;">
                                                    Product
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <span t-field="o.product_id.name"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="width:38%;">
                                                    Date
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <span t-field="o.date"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="width:38%;">
                                                    Description
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <span t-field="o.description"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                    <td style="width:50%;padding:0px;">
                                        <table class="table table-borderless">
                                            <tr>
                                                <td style="width:28%;">
                                                    Unit Price
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:70%;">
                                                    <strong>
                                                        <span t-field="o.unit_price"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="width:28%;">
                                                    Quantity
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:70%;">
                                                    <strong>
                                                        <span t-field="o.quantity"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="width:28%;">
                                                    Subtotal
                                                </td>
                                                <td style="width:2%;">
                                                    :
                                                </td>
                                                <td style="width:70%;">
                                                    <strong>
                                                        <span t-field="o.sub_total"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            <p style="page-break-before:always;"/>
                        </t>
                        <t t-if="len(o.expense_ids) &gt; 2">
                            <p style="page-break-before:always;"/>
                        </t>
                        <h6
                                style="padding-bottom:10px;padding-top:10px;background-color:#e9ecef;">
                            <i class="fa fa-credit-card me-1 ms-2" aria-hidden="true"/>
                            Expenses
                        </h6>
                        <table class="table table-borderless">
                            <tr style="border-bottom:1px solid black;">
                                <td>
                                    <strong>
                                        Expense Date
                                    </strong>
                                </td>
                                <td>
                                    <strong>
                                        Description
                                    </strong>
                                </td>
                                <td>
                                    <strong>
                                        Category
                                    </strong>
                                </td>
                                <td>
                                    <strong>
                                        Status
                                    </strong>
                                </td>
                                <td style="text-align:right;">
                                    <strong>
                                        Total
                                    </strong>
                                </td>
                            </tr>
                            <t t-foreach="o.expense_ids" t-as="e">
                                <tr style="border-bottom: 1px solid #cdc2c2;font-size:14px;">
                                    <td>
                                        <span t-field="e.date"/>
                                    </td>
                                    <td>
                                        <span t-field="e.name"/>
                                    </td>
                                    <td>
                                        <span t-field="e.product_id.name"/>
                                    </td>
                                    <td>
                                        <span t-field="e.state"/>
                                    </td>
                                    <td style="text-align:right;">
                                        <span t-field="e.total_amount_currency"
                                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                            <tr>
                                <td style="padding:1px;">
                                </td>
                                <td colspan="3" style="text-align:right;padding:1px;">
                                    <strong>Expense Total</strong>
                                </td>
                                <td style="text-align:right;padding:1px;">
                                    <strong>
                                        <span t-field="o.expense_total"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:1px;">
                                </td>
                                <td colspan="3" style="text-align:right;padding:1px;">
                                    <strong>Approve Expense Total</strong>
                                </td>
                                <td style="text-align:right;padding:1px;">
                                    <strong>
                                        <span t-field="o.approve_expense_total"/>
                                    </strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
    <!-- Report Action -->
    <record id="action_employee_travel_request_report" model="ir.actions.report">
        <field name="name">Travel Request Report</field>
        <field name="model">employee.travel.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tk_employee_travel_expense.employee_travel_request_report_template</field>
        <field name="report_file">tk_employee_travel_expense.employee_travel_request_report_template</field>
        <field name="binding_model_id" ref="tk_employee_travel_expense.model_employee_travel_request"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
