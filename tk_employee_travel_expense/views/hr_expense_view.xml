<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="inherit_view_hr_expense_view_form" model="ir.ui.view">
            <field name="name">inherit.view.hr.expense.view.form</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date']" position="after">
                    <field name="employee_travel_expense_id"
                           readonly="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>