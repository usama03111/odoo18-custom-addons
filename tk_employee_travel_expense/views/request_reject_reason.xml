<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--        Views-->
        <record id="request_reject_reason_view_list" model="ir.ui.view">
            <field name="name">request.reject.reason.view.list</field>
            <field name="model">request.reject.reason</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="request_reject_reason"/>
                    <field name="closing_notes"/>
                </list>
            </field>
        </record>
        <!--        Action-->
        <record id="request_reject_reason_action" model="ir.actions.act_window">
            <field name="name">Reject Reason</field>
            <field name="res_model">request.reject.reason</field>
            <field name="view_mode">list</field>
        </record>
    </data>
</odoo>