<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="transport_booking_fast.TransportBooking" owl="1">
        <div class="o_transport_booking p-4 container">
            <h1 class="mb-4 text-center">Transport Booking</h1>
            
            <div class="row g-3">
                <!-- Route Selection -->
                <div class="col-md-6">
                    <label for="routeSelect" class="form-label">Route</label>
                    <select id="routeSelect" class="form-select" t-model="state.selectedRoute">
                        <option value="">Select a Route</option>
                        <t t-foreach="state.routes" t-as="route" t-key="route.id">
                            <option t-att-value="route.id">
                                <t t-esc="route.name"/> (<t t-esc="route.start_location"/> -> <t t-esc="route.end_location"/>)
                            </option>
                        </t>
                    </select>
                </div>

                <!-- Vehicle Selection -->
                <div class="col-md-6">
                    <label for="vehicleSelect" class="form-label">Vehicle</label>
                    <select id="vehicleSelect" class="form-select" t-model="state.selectedVehicle">
                        <option value="">Select a Vehicle</option>
                        <t t-foreach="state.vehicles" t-as="vehicle" t-key="vehicle.id">
                            <option t-att-value="vehicle.id">
                                <t t-esc="vehicle.name"/> (Cap: <t t-esc="vehicle.capacity"/>)
                            </option>
                        </t>
                    </select>
                </div>

                <!-- Customer Name -->
                <div class="col-md-6">
                    <label for="customerName" class="form-label">Customer Name</label>
                    <input type="text" id="customerName" class="form-control" t-model="state.customerName" placeholder="Enter customer name"/>
                </div>

                <!-- Seats -->
                <div class="col-md-3">
                    <label for="seats" class="form-label">Seats</label>
                    <input type="number" id="seats" class="form-control" t-model="state.seats" min="1"/>
                </div>

                <!-- Amount -->
                <div class="col-md-3">
                    <label for="amount" class="form-label">Amount</label>
                    <input type="number" id="amount" class="form-control" t-model="state.amount" step="0.01"/>
                </div>
            </div>

            <div class="mt-4 text-center">
                <button class="btn btn-primary btn-lg px-5" t-on-click="confirmBooking">
                    Confirm Booking
                </button>
            </div>
        </div>
    </t>
</templates>
