<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_transport_batch_tree" model="ir.ui.view">
        <field name="name">transport.batch.tree</field>
        <field name="model">transport.batch</field>
        <field name="arch" type="xml">
            <list string="Manifests">
                <field name="name"/>
                <field name="date"/>
                <field name="vehicle_no"/>
                <field name="driver_name"/>
                <field name="total_weight"/>
                <field name="total_fare"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'loaded'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transport_batch_form" model="ir.ui.view">
        <field name="name">transport.batch.form</field>
        <field name="model">transport.batch</field>
        <field name="arch" type="xml">
            <form string="Vehicle Loading Manifest">
                <header>
                    <button name="action_load" string="Confirm / Load" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_ship" string="Ship" type="object" class="oe_highlight" invisible="state != 'loaded'"/>
                    <button name="action_arrive" string="Arrive" type="object" class="oe_highlight" invisible="state != 'shipped'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,loaded,shipped,arrived,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vehicle Details">
                            <field name="vehicle_no"/>
                            <field name="driver_name"/>
                            <field name="driver_phone"/>
                            <field name="date"/>
                        </group>
                        <group string="Totals">
                             <field name="total_weight"/>
                             <field name="total_fare"/>
                             <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Builties (Consignments)">
                            <field name="builty_ids" domain="[('state', '=', 'booked'), ('batch_id', '=', False)]">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="source_city_id"/>
                                    <field name="dest_city_id"/>
                                    <field name="item_count"/>
                                    <field name="weight"/>
                                    <field name="charges_fare"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transport_batch" model="ir.actions.act_window">
        <field name="name">Loading Manifests</field>
        <field name="res_model">transport.batch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Loading Manifest!
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_transport_batch" name="Manifests" parent="menu_transport_root" sequence="5" action="action_transport_batch"/>

</odoo>
