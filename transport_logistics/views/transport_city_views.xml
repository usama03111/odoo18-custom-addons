<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transport_city_tree" model="ir.ui.view">
        <field name="name">transport.city.tree</field>
        <field name="model">transport.city</field>
        <field name="arch" type="xml">
            <list string="Cities" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_transport_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">transport.city</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_transport_city" name="Cities" parent="menu_transport_config" action="action_transport_city"/>
</odoo>
