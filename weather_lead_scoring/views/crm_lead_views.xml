<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit_weather" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.weather</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add fields in the lead form  -->
            <xpath expr="//sheet//group[@name='lead_priority']" position="after">
                <group string="Weather">
                    <field name="x_weather_score"/>
                    <field name="x_temperature"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo> 