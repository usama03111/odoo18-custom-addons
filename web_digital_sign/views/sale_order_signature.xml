<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_order_form_inherit_signature" model="ir.ui.view">
        <field name="name">sale.order.form.digital.signature</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Locate the existing signature field and update it -->
            <xpath expr="//field[@name='signature']" position="attributes">
                <attribute name="widget">digital_signature</attribute>
            </xpath>
        </field>
    </record>
</odoo>
