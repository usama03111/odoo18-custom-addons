<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.whatsapp.mail.messaging
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id"
               ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pwa_settings']" position="after">
                <block title="WhatsApp Integration" id="whatsapp_message">
                    <setting string="Quick Message"
                            help="Quick WhatsApp message template (limited to 255 characters).">
                        <field name="whatsapp_message" placeholder="Enter a quick message..." widget="text_emojis" nolabel="1"/>
                    </setting>
                    
                    <setting string="Default Message Template"
                            help="Select a default message template for longer messages.">
                        <field name="whatsapp_message_template" placeholder="Select a template..."/>
                    </setting>
                    
                    <setting string="Enable WhatsApp API"
                            help="Enable webhook to receive WhatsApp messages">
                        <field name="whatsapp_api_enabled"/>
                    </setting>
                    
                    <setting string="API Provider" 
                            help="Select your WhatsApp API provider"
                            invisible="not whatsapp_api_enabled">
                        <field name="whatsapp_api_provider"/>
                    </setting>
                    
                    <setting string="Webhook URL" 
                            help="Configure this URL in your WhatsApp API provider"
                            invisible="not whatsapp_api_enabled">
                        <field name="whatsapp_webhook_url" readonly="1"/>
                        <button name="action_test_webhook" string="Test Webhook" type="object" class="btn-secondary"/>
                        <button name="action_check_settings" string="Check Settings" type="object" class="btn-info"/>
                        <button name="action_clear_settings" string="Clear Settings" type="object" class="btn-warning"/>
                    </setting>
                </block>
                
                <!-- Twilio Configuration -->
                <block title="Twilio Configuration" id="twilio_config"
                       invisible="not whatsapp_api_enabled or whatsapp_api_provider != 'twilio'">
                    <setting string="Account SID">
                        <field name="twilio_account_sid"/>
                    </setting>
                    <setting string="Auth Token">
                        <field name="twilio_auth_token" password="True"/>
                    </setting>
                    <setting string="WhatsApp Number">
                        <field name="twilio_phone_number"/>
                    </setting>
                </block>
                
                <!-- WhatsApp Business API Configuration -->
                <block title="WhatsApp Business API Configuration" id="whatsapp_business_config"
                       invisible="not whatsapp_api_enabled or whatsapp_api_provider != 'whatsapp_business'">
                    <setting string="Business Token">
                        <field name="whatsapp_business_token" password="True"/>
                    </setting>
                    <setting string="Phone ID">
                        <field name="whatsapp_business_phone_id"/>
                    </setting>
                    <setting string="Webhook Verify Token">
                        <field name="whatsapp_business_webhook_verify_token"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
